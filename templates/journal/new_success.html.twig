{% extends 'base.html.twig' %}

{% block title %}Entrée Créée | Journal{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('front/css/mood-journal-pro.css') }}">
{% endblock %}

{% block body %}
<div class="page-container" style="max-width: 900px; margin: 0 auto; padding: 2rem 1rem;">
    <!-- Success Message -->
    <div style="background: #d4edda; border-left: 4px solid #28a745; padding: 1.5rem; border-radius: 6px; margin-bottom: 2rem;">
        <h2 style="margin: 0; color: #155724; display: flex; align-items: center; gap: 10px;">
            <i class="fas fa-check-circle" style="font-size: 1.5rem;"></i>
            Votre entrée a été enregistrée ! ✨
        </h2>
        <p style="margin: 0.5rem 0 0 0; color: #155724;">Bravo ! Vous avez complété votre journal émotionnel.</p>
    </div>

    <!-- AI Analysis Section -->
    {% if ai_analysis %}
    <div style="background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); padding: 2rem; margin-bottom: 2rem;">
        <h3 style="display: flex; align-items: center; gap: 10px; margin-bottom: 1.5rem; color: #333;">
            <i class="fas fa-robot" style="color: #007bff;"></i>
            Analyse IA - Conseils Personnalisés
        </h3>

        <!-- Sentiment Section -->
        {% set sentiment_colors = {
            'triste': '#3498db',
            'stressé': '#e74c3c',
            'colère': '#c0392b',
            'heureux': '#2ecc71',
            'calme': '#9b59b6',
            'fatigue': '#f39c12',
            'excite': '#e67e22',
            'neutre': '#95a5a6'
        } %}
        <div style="background: linear-gradient(135deg, {{ sentiment_colors[ai_analysis.sentiment] ?? '#95a5a6' }} 0%, rgba(255,255,255,1) 100%); padding: 1.5rem; border-radius: 6px; margin-bottom: 1.5rem; border-left: 4px solid {{ sentiment_colors[ai_analysis.sentiment] ?? '#95a5a6' }};">
            <h4 style="margin: 0 0 0.5rem 0; color: #333;">Sentiment Détecté</h4>
            <p style="margin: 0; font-size: 1.2rem; font-weight: bold;">
                {{ ai_analysis.sentiment|upper }}
                <span style="font-size: 1.5rem; margin-left: 0.5rem;">
                    {% if ai_analysis.sentiment == 'triste' %}
                        😢
                    {% elseif ai_analysis.sentiment == 'stressé' %}
                        😰
                    {% elseif ai_analysis.sentiment == 'colère' %}
                        😠
                    {% elseif ai_analysis.sentiment == 'heureux' %}
                        😊
                    {% elseif ai_analysis.sentiment == 'calme' %}
                        🧘
                    {% elseif ai_analysis.sentiment == 'fatigue' %}
                        😴
                    {% elseif ai_analysis.sentiment == 'excite' %}
                        🎉
                    {% elseif ai_analysis.sentiment == 'neutre' %}
                        💭
                    {% else %}
                        💭
                    {% endif %}
                </span>
            </p>
        </div>

        <!-- Keywords Section -->
        {% if ai_analysis.keywords|length > 0 %}
        <div style="background: #f0f0f0; padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem;">
            <h4 style="margin: 0 0 0.5rem 0; color: #333;">Mots-clés détectés 🎯</h4>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                {% for keyword in ai_analysis.keywords %}
                <span style="background: #007bff; color: white; padding: 0.3rem 0.8rem; border-radius: 15px; font-size: 0.9rem;">
                    {{ keyword }}
                </span>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- AI Suggestions -->
        <div style="background: #e8f4f8; padding: 1.5rem; border-radius: 6px; margin-bottom: 1.5rem; border-left: 4px solid #17a2b8;">
            <h4 style="margin: 0 0 1rem 0; color: #333; display: flex; align-items: center; gap: 8px;">
                <i class="fas fa-lightbulb" style="color: #ffc107;"></i>
                Suggestions IA pour vous
            </h4>
            <ul style="margin: 0; padding-left: 1.5rem; list-style: none;">
                {% for suggestion in ai_analysis.suggestions %}
                <li style="margin-bottom: 0.8rem; padding-left: 1.5rem; position: relative; line-height: 1.5;">
                    <span style="position: absolute; left: 0;">→</span>
                    {{ suggestion }}
                </li>
                {% endfor %}
            </ul>
        </div>

        <!-- Wellness Tip -->
        <div style="background: #fff3cd; padding: 1.5rem; border-radius: 6px; border-left: 4px solid #ffc107;">
            <h4 style="margin: 0 0 0.5rem 0; color: #333; display: flex; align-items: center; gap: 8px;">
                <i class="fas fa-heart" style="color: #e74c3c;"></i>
                Conseil bien-être du jour
            </h4>
            <p style="margin: 0; line-height: 1.6; color: #333;">
                {{ ai_analysis.wellness_tip }}
            </p>
        </div>
    </div>
    {% endif %}

    <!-- PDF Generation Status -->
    <div style="background: linear-gradient(135deg, #e8f4f8 0%, #f0f8fc 100%); border-left: 4px solid #007bff; padding: 1.5rem; border-radius: 6px; margin-bottom: 2rem;">
        <h4 style="display: flex; align-items: center; gap: 10px; margin: 0 0 0.5rem 0; color: #0056b3;">
            <i class="fas fa-file-pdf" style="color: #dc3545;"></i>
            Génération du PDF
        </h4>
        <p style="margin: 0.5rem 0 0 0; color: #0056b3;">
            <i class="fas fa-spinner fa-spin me-2"></i>Votre PDF est en cours de génération. Vous pourrez le télécharger depuis la page des détails.
        </p>
    </div>

    <!-- Action Buttons -->
    <div style="display: flex; gap: 1rem; justify-content: center; margin-top: 2rem; flex-wrap: wrap;">
        <a href="{{ path('app_journal_emotionnel_show', {'id': journal_emotionnel.id}) }}" 
           style="background: #007bff; color: white; padding: 12px 24px; border-radius: 4px; text-decoration: none; display: inline-block; font-weight: bold;">
            👁️ Voir Détails & Télécharger PDF
        </a>
        <a href="{{ path('app_journal_emotionnel_index') }}" 
           style="background: #6c757d; color: white; padding: 12px 24px; border-radius: 4px; text-decoration: none; display: inline-block; font-weight: bold;">
            ← Retour à mes entrées
        </a>
        <a href="{{ path('app_journal_emotionnel_new') }}" 
           style="background: #28a745; color: white; padding: 12px 24px; border-radius: 4px; text-decoration: none; display: inline-block; font-weight: bold;">
            ✍️ Nouvelle entrée
        </a>
    </div>

    <!-- Progress & Gamification -->
    <div style="background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); padding: 1.5rem; margin-top: 2rem;">
        <h4 style="margin: 0 0 1rem 0; color: #333;">🎮 Progression</h4>
        <p style="margin: 0.5rem 0; color: #666;">
            <strong>+10 Points</strong> pour cette entrée du journal
        </p>
        <p style="margin: 0.5rem 0; color: #666;">
            Continuez à exprimer votre bien-être émotionnel ! 💪
        </p>
    </div>
</div>
{% endblock %}
