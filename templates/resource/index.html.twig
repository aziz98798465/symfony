{% extends 'base.html.twig' %}

{% block title %}Ressources Educatives | MindCare{% endblock %}

{% block body %}
<section class="resources-section py-5">
    <div class="container">
        <div class="resources-hero text-center mb-5">
            <h1 class="display-5 fw-bold mb-3">Ressources educatives</h1>
            <p class="hero-subtitle mx-auto mb-3">
                Des contenus utiles pour votre bien-etre mental.
            </p>
            <span class="resources-count-pill">
                {{ resources.getTotalItemCount is defined ? resources.getTotalItemCount : resources|length }} ressources
            </span>
        </div>

        <div class="row mb-5">
            <div class="col-lg-8 mx-auto">
                <div class="search-wrapper">
                    <div class="input-group input-group-lg">
                        <div class="input-group-prepend">
                            <span class="input-group-text search-icon-wrap"><i class="fa fa-search" aria-hidden="true"></i></span>
                        </div>
                        <input
                            type="text"
                            class="form-control"
                            placeholder="Rechercher une ressource..."
                            id="searchResources"
                        >
                    </div>
                </div>
            </div>
        </div>

        <div class="row" id="resourcesGrid">
            {% for resource in resources %}
                <div class="col-xl-4 col-md-6 mb-4 resource-card">
                    <article class="resource-card-inner h-100">
                        <div class="resource-media">
                            {% if resource.type == 'video' and resource.youtubeThumbnailUrl %}
                                <img
                                    src="{{ resource.youtubeThumbnailUrl }}"
                                    alt="Miniature de {{ resource.title }}"
                                    loading="lazy"
                                    onerror="this.style.display='none'; this.parentElement.classList.add('media-fallback');"
                                >
                                <span class="media-tag media-tag-video">Video</span>
                            {% elseif resource.imageUrl %}
                                <img
                                    src="{{ resource.imageUrl }}"
                                    alt="Image de {{ resource.title }}"
                                    loading="lazy"
                                    referrerpolicy="no-referrer"
                                    onerror="this.style.display='none'; this.parentElement.classList.add('media-fallback');"
                                >
                                <span class="media-tag">Article</span>
                            {% else %}
                                <div class="resource-media-placeholder">
                                    <span>{{ resource.type == 'video' ? 'VIDEO' : 'ARTICLE' }}</span>
                                </div>
                            {% endif %}
                        </div>

                        <div class="card-body p-4">
                            <h4 class="card-title mb-2">{{ resource.title }}</h4>

                            <p class="card-text text-muted mb-4">
                                {{ resource.description|length > 135
                                    ? resource.description|slice(0, 135) ~ '...'
                                    : resource.description }}
                            </p>

                            <div class="resource-meta d-flex justify-content-between align-items-center pt-3 border-top">
                                <div class="date d-flex align-items-center">
                                    <i class="fa fa-calendar text-muted mr-2" aria-hidden="true"></i>
                                    <small class="text-muted">{{ resource.createdAt|date('d/m/Y') }}</small>
                                </div>
                                <div class="comments d-flex align-items-center">
                                    <i class="fa fa-comments text-muted mr-2" aria-hidden="true"></i>
                                    <small class="text-muted">{{ resource.commentaires|length }}</small>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-transparent border-0 p-4 pt-0">
                            <div class="resource-actions d-flex justify-content-between align-items-center">
                                <a href="{{ path('resource_show', {id: resource.id}) }}" class="btn btn-primary btn-sm px-4">
                                    <i class="fa fa-eye mr-1" aria-hidden="true"></i>Voir
                                </a>

                                {% if resource.filePath %}
                                    <a
                                        href="{{ asset('uploads/resources/' ~ resource.filePath) }}"
                                        target="_blank"
                                        class="btn btn-outline-primary btn-sm px-4"
                                        rel="noopener"
                                    >
                                        <i class="fa fa-download mr-1" aria-hidden="true"></i>Fichier
                                    </a>
                                {% elseif resource.type == 'video' and resource.videoUrl %}
                                    <a
                                        href="{{ resource.videoUrl }}"
                                        target="_blank"
                                        class="btn btn-outline-primary btn-sm px-4"
                                        rel="noopener"
                                    >
                                        <i class="fa fa-external-link mr-1" aria-hidden="true"></i>YouTube
                                    </a>
                                {% elseif resource.imageUrl %}
                                    <a
                                        href="{{ resource.imageUrl }}"
                                        target="_blank"
                                        class="btn btn-outline-primary btn-sm px-4"
                                        rel="noopener"
                                    >
                                        <i class="fa fa-image mr-1" aria-hidden="true"></i>Image
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </article>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="empty-state text-center py-5">
                        <i class="fa fa-inbox fa-3x text-muted mb-3" aria-hidden="true"></i>
                        <h4 class="mb-2">Aucune ressource disponible</h4>
                        <p class="text-muted mb-0">Aucune ressource publiee pour le moment.</p>
                    </div>
                </div>
            {% endfor %}
        </div>

        {% if resources.pageCount is defined and resources.pageCount > 1 %}
            <div class="resource-pagination mt-5">
                {{ knp_pagination_render(resources, '@KnpPaginator/Pagination/twitter_bootstrap_v4_pagination.html.twig') }}
            </div>
        {% endif %}
    </div>
</section>

<style>
.resources-section {
    background:
        radial-gradient(circle at 90% 0, rgba(13, 110, 253, 0.08), transparent 35%),
        radial-gradient(circle at 0 100%, rgba(25, 135, 84, 0.07), transparent 28%),
        #f4f7fb;
    min-height: 72vh;
}

.resources-hero {
    max-width: 760px;
    margin: 0 auto;
}

.hero-subtitle {
    max-width: 620px;
    color: #5f6b7a;
    font-size: 1.06rem;
}

.resources-count-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    background: #ffffff;
    border: 1px solid rgba(13, 110, 253, 0.2);
    color: #2754a6;
    font-weight: 600;
    font-size: 0.9rem;
}

.search-wrapper {
    background: #fff;
    border-radius: 14px;
    padding: 10px;
    box-shadow: 0 10px 25px rgba(16, 24, 40, 0.08);
    border: 1px solid rgba(15, 23, 42, 0.06);
}

.search-wrapper .form-control {
    border: none;
    box-shadow: none;
    font-size: 1rem;
}

.search-wrapper .input-group-text {
    border: none;
    background: transparent;
    color: #8091a7;
}

.resource-card-inner {
    border-radius: 16px;
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 14px 30px rgba(16, 24, 40, 0.07);
    overflow: hidden;
    transition: transform 0.26s ease, box-shadow 0.26s ease;
}

.resource-card-inner:hover {
    transform: translateY(-6px);
    box-shadow: 0 22px 38px rgba(16, 24, 40, 0.12);
}

.resource-media {
    position: relative;
    width: 100%;
    height: 208px;
    overflow: hidden;
    background: #ecf1f8;
}

.resource-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.resource-media.media-fallback::after {
    content: "Image non disponible";
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    font-size: 0.95rem;
    font-weight: 600;
}

.resource-media-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b;
    font-weight: 700;
    letter-spacing: 0.08em;
}

.media-tag {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(13, 110, 253, 0.92);
    color: #fff;
    font-size: 0.72rem;
    padding: 4px 10px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}

.media-tag-video {
    background: rgba(220, 53, 69, 0.92);
}

.card-title {
    color: #1f2f46;
    font-weight: 700;
    font-size: 1.85rem;
    line-height: 1.3;
    min-height: 4.7rem;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
}

.card-text {
    font-size: 0.95rem;
    line-height: 1.6;
    min-height: 3rem;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
}

.resource-actions {
    gap: 10px;
}

.resource-actions .btn {
    border-radius: 10px;
    font-weight: 600;
}

.empty-state {
    background: #fff;
    border-radius: 16px;
    border: 1px solid rgba(15, 23, 42, 0.08);
}

.resource-pagination {
    display: flex;
    justify-content: center;
}

.resource-pagination .pagination {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0;
    flex-wrap: wrap;
}

.resource-pagination .page-item .page-link {
    border: none;
    min-width: 42px;
    height: 42px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #2a4365;
    background: #fff;
    box-shadow: 0 6px 14px rgba(16, 24, 40, 0.08);
    font-weight: 600;
}

.resource-pagination .page-item .page-link:hover {
    background: #0d6efd;
    color: #fff;
}

.resource-pagination .page-item.active .page-link {
    background: linear-gradient(135deg, #0d6efd, #3b82f6);
    color: #fff;
}

.resource-pagination .page-item.disabled .page-link {
    color: #a7b3c2;
    box-shadow: none;
}

@media (max-width: 768px) {
    .resource-actions {
        flex-direction: column;
    }

    .resource-actions .btn {
        width: 100%;
    }

    .display-5 {
        font-size: 2rem;
    }

    .resource-media {
        height: 190px;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchResources');
    const resourceCards = document.querySelectorAll('.resource-card');

    if (searchInput && resourceCards.length > 0) {
        searchInput.addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase().trim();

            resourceCards.forEach(function(card) {
                const title = card.querySelector('.card-title').textContent.toLowerCase();
                const description = card.querySelector('.card-text').textContent.toLowerCase();

                card.style.display = searchTerm === '' || title.includes(searchTerm) || description.includes(searchTerm)
                    ? ''
                    : 'none';
            });
        });
    }

    document.querySelectorAll('.resource-card-inner').forEach(function(card) {
        card.addEventListener('click', function(event) {
            if (!event.target.closest('a') && !event.target.closest('button')) {
                const link = this.querySelector('a.btn-primary');
                if (link) {
                    link.click();
                }
            }
        });
    });
});
</script>

