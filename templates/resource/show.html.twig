{% extends 'base.html.twig' %}

{% block title %}{{ resource.title }} | MindCare{% endblock %}

{% block body %}
{% set approvedComments = resource.commentaires|filter(commentaire => commentaire.approved) %}
<div class="container py-5 resource-show-page">
    <div class="row mb-5">
        <div class="col-12">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('resource_index') }}">Ressources</a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{ resource.title }}</li>
                </ol>
            </nav>
            <h1 class="display-5 fw-bold" id="resource-title">{{ resource.title }}</h1>
            <p class="text-muted">
                Publie le {{ resource.createdAt|date('d/m/Y H:i') }}
                <span class="relative-time">({{ time_diff(resource.createdAt, null, 'fr') }})</span>
                | {{ approvedComments|length }} commentaire(s)
            </p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-5">
                <div class="card-body">
                    {% if resource.type == 'video' and resource.youtubeEmbedUrl %}
                        <div class="resource-video-wrapper mb-4">
                            <iframe
                                src="{{ resource.youtubeEmbedUrl }}"
                                title="{{ resource.title }}"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen
                                loading="lazy"
                            ></iframe>
                        </div>
                    {% elseif resource.type == 'article' and resource.imageUrl %}
                        <div class="resource-image-wrapper mb-4">
                            <img
                                src="{{ resource.imageUrl }}"
                                alt="Image de {{ resource.title }}"
                                loading="lazy"
                                referrerpolicy="no-referrer"
                                onerror="this.style.display='none'; this.parentElement.classList.add('is-broken');"
                            >
                        </div>
                    {% endif %}

                    <p class="resource-description mb-4" id="resource-description">{{ resource.description }}</p>

                    {# ── Translation widget ── #}
                    <div class="translate-widget mb-4 p-3 rounded" style="background:#f8f9ff; border:1px solid #e0e4f0;">
                        <div class="d-flex align-items-center flex-wrap gap-2">
                            <span style="font-size:.85rem; font-weight:600; color:#555;">
                                🌐 Traduire :
                            </span>
                            <button onclick="translateResource('en')" class="btn btn-sm btn-outline-secondary translate-btn" data-lang="en">🇬🇧 Anglais</button>
                            <button onclick="translateResource('ar')" class="btn btn-sm btn-outline-secondary translate-btn" data-lang="ar">🇸🇦 Arabe</button>
                            <button onclick="translateResource('de')" class="btn btn-sm btn-outline-secondary translate-btn" data-lang="de">🇩🇪 Allemand</button>
                            <button onclick="translateResource('es')" class="btn btn-sm btn-outline-secondary translate-btn" data-lang="es">🇪🇸 Espagnol</button>
                            <button onclick="translateResource('fr')" class="btn btn-sm btn-outline-secondary translate-btn" data-lang="fr">🇫🇷 Français</button>
                            <span id="translate-spinner" style="display:none;">
                                <span class="spinner-border spinner-border-sm text-primary ms-2" role="status"></span>
                                <small class="text-muted ms-1">Traduction...</small>
                            </span>
                        </div>
                        <div id="translate-error" class="text-danger mt-2" style="display:none; font-size:.85rem;"></div>
                    </div>

                    <div class="resource-actions">
                        {% if resource.type == 'video' and resource.videoUrl %}
                            <a href="{{ resource.videoUrl }}" target="_blank" rel="noopener" class="btn btn-outline-primary">
                                <i class="fa fa-external-link mr-1" aria-hidden="true"></i>Voir sur YouTube
                            </a>
                        {% endif %}

                        {% if resource.filePath %}
                            <a href="{{ asset('uploads/resources/' ~ resource.filePath) }}" target="_blank" rel="noopener" class="btn btn-primary">
                                <i class="fa fa-download mr-1" aria-hidden="true"></i>Telecharger le fichier
                            </a>
                        {% endif %}

                        {% if resource.type == 'article' and resource.imageUrl %}
                            <a href="{{ resource.imageUrl }}" target="_blank" rel="noopener" class="btn btn-outline-primary">
                                <i class="fa fa-image mr-1" aria-hidden="true"></i>Ouvrir l'image
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="comments-section mb-5">
                <h3>Commentaires ({{ approvedComments|length }})</h3>

                {% if approvedComments|length > 0 %}
                    {% for commentaire in approvedComments|sort((a, b) => b.createdAt <=> a.createdAt) %}
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong>{{ commentaire.authorName }}</strong>
                                        <small class="text-muted">
                                            - {{ commentaire.createdAt|date('d/m/Y H:i') }}
                                            <span class="relative-time">({{ time_diff(commentaire.createdAt, null, 'fr') }})</span>
                                        </small>
                                    </div>
                                    {% if app.user and (is_granted('ROLE_ADMIN') or (commentaire.user and commentaire.user.id == app.user.id)) %}
                                        <form action="{{ path('commentaire_delete', {'id': commentaire.id}) }}" method="post" class="d-inline ml-2" onsubmit="return confirm('Supprimer ce commentaire ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commentaire.id) }}">
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                <i class="fa fa-trash mr-1" aria-hidden="true"></i>Supprimer
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>

                                {% if commentaire.rating %}
                                    <div class="stars mb-2" aria-label="Note {{ commentaire.rating }} sur 5">
                                        {% for i in 1..5 %}
                                            <span class="star {{ i <= commentaire.rating ? 'is-filled' : '' }}">&#9733;</span>
                                        {% endfor %}
                                        <small class="ml-2">{{ commentaire.rating }}/5</small>
                                    </div>
                                {% endif %}

                                <p class="mb-0">{{ commentaire.content }}</p>
                            </div>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="alert alert-info">
                        <i class="fa fa-info-circle mr-2" aria-hidden="true"></i>
                        Aucun commentaire pour cette ressource. Soyez le premier a commenter.
                    </div>
                {% endif %}
            </div>

            {% if app.user %}
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h4>Ajouter un commentaire</h4>
                        <p class="text-muted mb-4">Vous commentez en tant que <strong>{{ app.user.firstName }} {{ app.user.lastName }}</strong></p>

                        {{ form_start(commentForm, {'attr': {'id': 'commentForm'}}) }}
                            {{ form_errors(commentForm) }}

                            <div class="mb-3">
                                {{ form_label(commentForm.content) }}
                                {{ form_widget(commentForm.content, {'attr': {'class': 'form-control', 'rows': 5}}) }}
                                {{ form_errors(commentForm.content) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(commentForm.rating) }}
                                <div class="star-rating-input" aria-label="Selection de la note">
                                    {% for choice in commentForm.rating %}
                                        {{ form_widget(choice, {'attr': {'class': 'star-input'}}) }}
                                        <label class="star-label" for="{{ choice.vars.id }}" title="{{ choice.vars.value }}/5">&#9733;</label>
                                    {% endfor %}
                                </div>
                                <small class="text-muted d-block mt-1">Cliquez sur les etoiles pour noter cette ressource.</small>
                                {{ form_errors(commentForm.rating) }}
                            </div>

                            {{ form_widget(commentForm.authorName) }}
                            {{ form_widget(commentForm.authorEmail) }}

                            <div class="d-flex justify-content-end align-items-center">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-paper-plane mr-2" aria-hidden="true"></i>Publier le commentaire
                                </button>
                            </div>
                        {{ form_end(commentForm) }}
                    </div>
                </div>
            {% else %}
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center">
                        <h5>Connectez-vous pour commenter</h5>
                        <p class="text-muted mb-4">Vous devez etre connecte pour ajouter un commentaire a cette ressource.</p>
                        <a href="{{ path('app_login') }}" class="btn btn-primary mr-2">
                            <i class="fa fa-sign-in mr-2" aria-hidden="true"></i>Se connecter
                        </a>
                        <a href="{{ path('app_register') }}" class="btn btn-outline-primary">
                            <i class="fa fa-user-plus mr-2" aria-hidden="true"></i>S'inscrire
                        </a>
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <i class="fa fa-book mr-2" aria-hidden="true"></i>Autres ressources
                </div>
                <div class="card-body">
                    {% for other in all_resources %}
                        {% if other.id != resource.id %}
                            <div class="mb-3 pb-2 {% if not loop.last %}border-bottom{% endif %}">
                                <a href="{{ path('resource_show', {'id': other.id}) }}" class="text-decoration-none">
                                    <h6 class="mb-1">{{ other.title }}</h6>
                                </a>
                                <small class="text-muted">
                                    <i class="fa fa-calendar mr-1" aria-hidden="true"></i>
                                    {{ other.createdAt|date('d/m/Y') }}
                                </small>
                            </div>
                        {% endif %}
                    {% else %}
                        <p class="text-muted mb-0">Aucune autre ressource disponible.</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.resource-video-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    background: #000;
}

.resource-video-wrapper iframe {
    width: 100%;
    height: 100%;
    border: 0;
}

.resource-image-wrapper {
    width: 100%;
    max-height: 520px;
    border-radius: 10px;
    overflow: hidden;
    background: #eef2f6;
    position: relative;
}

.resource-image-wrapper img {
    width: 100%;
    display: block;
    object-fit: cover;
}

.resource-image-wrapper.is-broken::after {
    content: "Image non disponible";
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #667085;
    font-weight: 600;
}

.resource-description {
    line-height: 1.7;
}

.resource-actions .btn {
    margin-right: 8px;
    margin-bottom: 8px;
}

.relative-time {
    color: #0d6efd;
    font-weight: 600;
}

.stars {
    font-size: 1rem;
}

.star {
    color: #d0d5dd;
    font-size: 1.1rem;
}

.star.is-filled {
    color: #f5b301;
}

.star-rating-input {
    display: inline-flex;
    flex-direction: row-reverse;
    align-items: center;
}

.star-input {
    position: absolute;
    left: -9999px;
}

.star-label {
    color: #c7c7c7;
    cursor: pointer;
    font-size: 2rem;
    line-height: 1;
    margin-right: 3px;
    transition: color 0.15s ease;
}

.star-label:hover,
.star-label:hover ~ .star-label,
.star-input:checked ~ .star-label {
    color: #f5b301;
}

@media (max-width: 992px) {
    .resource-video-wrapper {
        aspect-ratio: 16 / 10;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const commentForm = document.getElementById('commentForm');
    if (commentForm) {
        commentForm.addEventListener('submit', function() {
            const submitBtn = this.querySelector('button[type="submit"]');
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fa fa-spinner fa-spin mr-2" aria-hidden="true"></i>Publication...';
            }
        });
    }
});
</script>

{# ── Chatbot flottant Ressources ── #}
{% include 'partials/_chatbot_widget.html.twig' %}

<script>
const originalTitle       = document.getElementById('resource-title').innerText;
const originalDescription = document.getElementById('resource-description').innerText;
let currentLang = 'fr';

function translateResource(lang) {
    if (lang === currentLang) return;

    const spinner   = document.getElementById('translate-spinner');
    const errBox    = document.getElementById('translate-error');
    const btns      = document.querySelectorAll('.translate-btn');

    errBox.style.display = 'none';
    spinner.style.display = 'inline-flex';
    btns.forEach(b => b.disabled = true);

    fetch('{{ path('translate') }}', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
            texts: { title: originalTitle, description: originalDescription },
            target: lang
        })
    })
    .then(r => r.json())
    .then(data => {
        if (data.error) throw new Error(data.error);
        document.getElementById('resource-title').innerText       = data.translations.title;
        document.getElementById('resource-description').innerText = data.translations.description;
        currentLang = lang;
        // Highlight active button
        btns.forEach(b => {
            b.classList.toggle('btn-primary',         b.dataset.lang === lang);
            b.classList.toggle('text-white',          b.dataset.lang === lang);
            b.classList.toggle('btn-outline-secondary', b.dataset.lang !== lang);
        });
    })
    .catch(err => {
        errBox.textContent = err.message || 'Erreur de traduction.';
        errBox.style.display = 'block';
    })
    .finally(() => {
        spinner.style.display = 'none';
        btns.forEach(b => b.disabled = false);
    });
}
</script>

{% endblock %}
