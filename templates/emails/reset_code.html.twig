<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            font-family: 'Poppins', Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            margin: 0;
            padding: 0;
            background-color: #f4f4f4;
        }
        .container {
            max-width: 600px;
            margin: 20px auto;
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
        .header {
            background: -webkit-linear-gradient(left, #003366, #004080, #0059b3, #0073e6);
            padding: 30px;
            text-align: center;
        }
        .header h1 {
            color: white;
            margin: 0;
            font-size: 28px;
            font-weight: 600;
        }
        .content {
            padding: 40px 30px;
            background: white;
        }
        .code-box {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 30px;
            text-align: center;
            border-radius: 15px;
            margin: 30px 0;
        }
        .code {
            font-size: 48px;
            font-weight: 700;
            letter-spacing: 8px;
            color: white;
            font-family: monospace;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        .expiry {
            color: #dc3545;
            font-size: 14px;
            margin-top: 20px;
            text-align: center;
        }
        .footer {
            padding: 20px;
            text-align: center;
            background: #f8f9fa;
            color: #666;
            font-size: 12px;
        }
        .btn {
            display: inline-block;
            padding: 12px 30px;
            background: -webkit-linear-gradient(left, #003366, #0073e6);
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 500;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🔐 MindCare</h1>
        </div>
        
        <div class="content">
            <h2 style="margin-top:0; color:#333;">Hello {{ name }}!</h2>
            
            <p style="font-size:16px;">We received a request to reset your password.</p>
            
            <div class="code-box">
                <div style="color:rgba(255,255,255,0.9); margin-bottom:15px;">Your verification code is:</div>
                <div class="code">{{ code }}</div>
            </div>
            
            <p style="font-size:16px;">Enter this code in the verification page to reset your password.</p>
            
            <p class="expiry">⏰ This code will expire in 15 minutes.</p>
            
            <p style="font-size:14px; color:#666; margin-top:30px;">
                If you didn't request this, please ignore this email or contact support.
            </p>
            
            <div style="text-align: center;">
                <a href="http://127.0.0.1:8000/verify-code" class="btn">Verify Code</a>
            </div>
        </div>
        
        <div class="footer">
            <p>&copy; {{ "now"|date("Y") }} MindCare. All rights reserved.</p>
            <p style="margin-top:10px;">This is an automated message, please do not reply.</p>
        </div>
    </div>
</body>
</html>