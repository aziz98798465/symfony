{% extends 'base.html.twig' %}

{% block title %}MindCare | Accueil{% endblock %}

{% block body %}
    <!--[if lte IE 9]>
            <p class="browserupgrade">You are using an <strong>outdated</strong> browser. Please <a href="https://browsehappy.com/">upgrade your browser</a> to improve your experience and security.</p>
        <![endif]-->

    <!-- slider_area_start -->
    <div class="slider_area">
        <div class="slider_active owl-carousel">
            <div class="single_slider  d-flex align-items-center slider_bg_1">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="slider_text ">
                                <h3> <span>MindCare</span> <br>
                                    Votre partenaire pour une santé mentale équilibrée. </h3>
                                <p>Des ressources, des conseils et un accompagnement pour votre bien-être psychologique.</p>
                                <a href="aboutus.html" class="boxed-btn3">En savoir plus</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="single_slider  d-flex align-items-center slider_bg_2">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="slider_text ">
                                <h3> <span>MindCare</span> <br>
                                    Un espace dédié à votre bien-être mental. </h3>
                                <p>Participez à des programmes de suivi et trouvez des solutions adaptées.</p>
                                <a href="aboutus.html" class="boxed-btn3">Découvrir</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="single_slider  d-flex align-items-center slider_bg_1">
                <div class="container">
                    <div class="row">
                        <div class="col-xl-12">
                            <div class="slider_text ">
                                <h3> <span>MindCare</span> <br>
                                    Ensemble, construisons un avenir serein. </h3>
                                <p>Explorez des outils et des astuces pour gérer votre stress et vos émotions.</p>
                                <a href="aboutus.html" class="boxed-btn3">Commencer</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- slider_area_end -->

    <!-- service_area_start -->
    <div class="service_area">
        <div class="container p-0">
            <div class="row no-gutters">
                <div class="col-xl-4 col-md-4">
                    <div class="single_service">
                        <div class="icon">
                            <i class="flaticon-electrocardiogram"></i>
                        </div>
                        <h3>Suivi d'Humeur</h3>
                        <p>Gardez une trace de vos émotions et découvrez des tendances pour mieux vous comprendre.</p>
                        <a href="moodtracker.html" class="boxed-btn3-white">Accéder</a>
                    </div>
                </div>
                <div class="col-xl-4 col-md-4">
                    <div class="single_service">
                        <div class="icon">
                            <i class="flaticon-emergency-call"></i>
                        </div>
                        <h3>Contact avec un Psychologue</h3>
                        <p>Connectez-vous avec des experts pour un accompagnement professionnel.</p>
                        <a href="psychologists.html" class="boxed-btn3-white">Consulter</a>
                    </div>
                </div>
                <div class="col-xl-4 col-md-4">
                    <div class="single_service">
                        <div class="icon">
                            <i class="flaticon-first-aid-kit"></i>
                        </div>
                        <h3>Ressources & Conseils</h3>
                        <p>Accédez à des articles et des outils pour améliorer votre bien-être.</p>
                        <a href="articles.html" class="boxed-btn3-white">Explorer</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- service_area_end -->

    <!-- welcome_docmed_area_start -->
    <div class="welcome_docmed_area">
        <div class="container">
            <div class="row">
                <div class="col-xl-6 col-lg-6">
                    <div class="welcome_thumb">
                        <div class="thumb_1">
                            <img src="img/about/1.png" alt="">
                        </div>
                        <div class="thumb_2">
                            <img src="img/about/2.png" alt="">
                        </div>
                    </div>
                </div>
                <div class="col-xl-6 col-lg-6">
                    <div class="welcome_docmed_info">
                        <h2>Bienvenue sur MindCare</h2>
                        <h3>Un soutien pour chaque étape de votre parcours.</h3>
                        <p>MindCare est conçu pour accompagner les étudiants et les professionnels dans la gestion du stress, l'amélioration de la santé mentale et la promotion du bien-être global.</p>
                        <ul>
                            <li> <i class="flaticon-right"></i> Suivi personnalisé de votre humeur.</li>
                            <li> <i class="flaticon-right"></i> Conseils pratiques et ressources fiables.</li>
                            <li> <i class="flaticon-right"></i> Accès à des experts pour des consultations en ligne.</li>
                        </ul>
                        <a href="aboutus.html" class="boxed-btn3-white">En savoir plus</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- welcome_docmed_area_end -->

    <!-- event_categories_area_start -->
    <div style="padding: 100px 0; background: linear-gradient(135deg, #f8faff 0%, #f0f9ff 100%);">
        <div class="container">
            <div class="row">
                <div class="col-xl-12">
                    <div class="section_title text-center mb-55">
                        <h3 style="font-size: 36px; font-weight: 800; color: #1e3a8a;">Catégories d'Événements</h3>
                        <p style="font-size: 16px; color: #64748b;">Explorez nos événements par catégorie et trouvez ce qui vous intéresse</p>
                    </div>
                </div>
            </div>
            <div class="row g-4">
                <!-- Sport Category -->
                <div class="col-xl-4 col-md-6">
                    <a href="{{ path('front_events_index', {'category': 'sport'}) }}" style="text-decoration: none; display: block;">
                        <div style="background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.08); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); height: 100%;">
                            <div style="background: linear-gradient(135deg, #3b82f6 0%, #1e40af 100%); padding: 60px 20px; text-align: center; color: white;">
                                <i class="flaticon-first-aid-kit" style="font-size: 80px; opacity: 0.3; margin-bottom: 20px;"></i>
                                <h4 style="font-size: 32px; font-weight: 700; margin: 0; text-transform: uppercase; letter-spacing: 1px;">Sport</h4>
                            </div>
                            <div style="padding: 24px; text-align: center;">
                                <p style="color: #64748b; margin: 0; font-size: 14px; line-height: 1.6;">Participez à nos événements sportifs et restez actif pour votre santé mentale.</p>
                            </div>
                            <div style="text-align: center; padding-bottom: 20px;">
                                <span style="color: #3b82f6; font-weight: 600; font-size: 13px;">Explorez →</span>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Bien-être Category -->
                <div class="col-xl-4 col-md-6">
                    <a href="{{ path('front_events_index', {'category': 'wellness'}) }}" style="text-decoration: none; display: block;">
                        <div style="background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.08); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); height: 100%;">
                            <div style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); padding: 60px 20px; text-align: center; color: white;">
                                <i class="flaticon-electrocardiogram" style="font-size: 80px; opacity: 0.3; margin-bottom: 20px;"></i>
                                <h4 style="font-size: 32px; font-weight: 700; margin: 0; text-transform: uppercase; letter-spacing: 1px;">Bien-être</h4>
                            </div>
                            <div style="padding: 24px; text-align: center;">
                                <p style="color: #64748b; margin: 0; font-size: 14px; line-height: 1.6;">Découvrez des séances de relaxation et de méditation pour vous ressourcer.</p>
                            </div>
                            <div style="text-align: center; padding-bottom: 20px;">
                                <span style="color: #10b981; font-weight: 600; font-size: 13px;">Explorez →</span>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Atelier Category -->
                <div class="col-xl-4 col-md-6">
                    <a href="{{ path('front_events_index', {'category': 'workshop'}) }}" style="text-decoration: none; display: block;">
                        <div style="background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.08); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); height: 100%;">
                            <div style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); padding: 60px 20px; text-align: center; color: white;">
                                <i class="flaticon-emergency-call" style="font-size: 80px; opacity: 0.3; margin-bottom: 20px;"></i>
                                <h4 style="font-size: 32px; font-weight: 700; margin: 0; text-transform: uppercase; letter-spacing: 1px;">Atelier</h4>
                            </div>
                            <div style="padding: 24px; text-align: center;">
                                <p style="color: #64748b; margin: 0; font-size: 14px; line-height: 1.6;">Assistez à nos ateliers interactifs et développez vos compétences.</p>
                            </div>
                            <div style="text-align: center; padding-bottom: 20px;">
                                <span style="color: #f59e0b; font-weight: 600; font-size: 13px;">Explorez →</span>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <!-- event_categories_area_end -->

    <!-- offers_area_start -->
    <div class="our_department_area">
        <div class="container">
            <div class="row">
                <div class="col-xl-12">
                    <div class="section_title text-center mb-55">
                        <h3>Nos Services</h3>
                        <p>Découvrez les outils et services que nous proposons pour soutenir votre bien-être mental.</p>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-xl-4 col-md-6 col-lg-4">
                    <div class="single_department">
                        <div class="department_thumb">
                            <img src="img/department/1.png" alt="">
                        </div>
                        <div class="department_content">
                            <h3><a href="moodtracker.html">Suivi d'Humeur</a></h3>
                            <p>Analysez vos émotions et améliorez votre santé mentale.</p>
                            <a href="moodtracker.html" class="learn_more">Voir plus</a>
                        </div>
                    </div>
                </div>
                <div class="col-xl-4 col-md-6 col-lg-4">
                    <div class="single_department">
                        <div class="department_thumb">
                            <img src="img/department/2.png" alt="">
                        </div>
                        <div class="department_content">
                            <h3><a href="psychologists.html">Consultation Psychologue</a></h3>
                            <p>Parlez à des experts qualifiés pour un accompagnement personnalisé.</p>
                            <a href="psychologists.html" class="learn_more">Voir plus</a>
                        </div>
                    </div>
                </div>
                <div class="col-xl-4 col-md-6 col-lg-4">
                    <div class="single_department">
                        <div class="department_thumb">
                            <img src="img/department/3.png" alt="">
                        </div>
                        <div class="department_content">
                            <h3><a href="articles.html">Ressources & Articles</a></h3>
                            <p>Accédez à des articles et outils pour améliorer votre bien-être.</p>
                            <a href="articles.html" class="learn_more">Voir plus</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- offers_area_end -->

    <!-- emergency_contact start -->
    <div class="Emergency_contact">
        <div class="conatiner-fluid p-0">
            <div class="row no-gutters">
                <div class="col-xl-6">
                    <div class="single_emergency d-flex align-items-center justify-content-center emergency_bg_1 overlay_skyblue">
                        <div class="info">
                            <h3>Besoin d'un soutien immédiat ?</h3>
                            <p>Contactez-nous pour une aide rapide et efficace.</p>
                        </div>
                        <div class="info_button">
                            <a href="contact.html" class="boxed-btn3-white">Contact</a>
                        </div>
                    </div>
                </div>
                <div class="col-xl-6">
                    <div class="single_emergency d-flex align-items-center justify-content-center emergency_bg_2 overlay_skyblue">
                        <div class="info">
                            <h3>Suivi d'humeur personnalisé</h3>
                            <p>Commencez votre suivi et améliorez votre bien-être mental.</p>
                        </div>
                        <div class="info_button">
                            <a href="moodtracker.html" class="boxed-btn3-white">Commencer</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- emergency_contact end -->

{% endblock %}
