{% extends 'admin/base_admin.html.twig' %}

{% block page_title %}Gestion Evenements{% endblock %}

{% block body %}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5>Liste des Evenements</h5>
        <a href="{{ path('admin_events_new') }}" class="btn btn-primary btn-sm">Ajouter Evenement</a>
    </div>
    <div class="card-body">
        {% if events is empty %}
            <p>Aucun evenement trouve.</p>
        {% else %}
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Titre</th>
                        <th>Date</th>
                        <th>Lieu</th>
                        <th>Capacite</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for event in events %}
                        <tr>
                            <td>{{ event.id }}</td>
                            <td>{{ event.titre }}</td>
                            <td>{{ event.dateEvent ? event.dateEvent|date('d/m/Y H:i') : '' }}</td>
                            <td>{{ event.lieu }}</td>
                            <td>{{ event.capacite }}</td>
                            <td>
                                <a href="{{ path('admin_events_edit', {id: event.id}) }}" class="btn btn-sm btn-warning">Editer</a>
                                <form method="post" action="{{ path('admin_events_delete', {id: event.id}) }}" style="display:inline-block;" onsubmit="return confirm('Voulez-vous vraiment supprimer cet evenement ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_event_' ~ event.id) }}">
                                    <button class="btn btn-sm btn-danger">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
