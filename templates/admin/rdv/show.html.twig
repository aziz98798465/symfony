{% extends 'admin/base_admin.html.twig' %}

{% block title %}Détails Rendez-vous{% endblock %}

{% block body %}
    <div class="container-fluid">
        <h1 class="mb-4">Rendez-vous #{{ appointment.getId() }}</h1>

        <div class="card">
            <div class="card-body">
                <p><strong>Étudiant:</strong> {{ appointment.getEtudiant() ? appointment.getEtudiant().getFirstName() ~ ' ' ~ appointment.getEtudiant().getLastName() : '-' }}</p>
                {% if is_granted('ROLE_ADMIN') %}
                    <p><strong>Psychologue:</strong> {{ appointment.getPsychologue() ? appointment.getPsychologue().getFirstName() ~ ' ' ~ appointment.getPsychologue().getLastName() : '-' }}</p>
                {% endif %}
                <p><strong>Date:</strong> {{ appointment.getDate() ? appointment.getDate().format('d/m/Y H:i') : '' }}</p>
                <p><strong>Mode:</strong> 
                    {% if appointment.getLocation() == 'in_office' %}
                        <span class="badge bg-primary">En cabinet</span>
                    {% else %}
                        <span class="badge bg-info">En ligne</span>
                    {% endif %}
                </p>
                <p><strong>Status:</strong> 
                    {% if appointment.getStatus() == 'pending' %}
                        <span class="badge bg-warning">En attente</span>
                    {% elseif appointment.getStatus() == 'accepted' %}
                        <span class="badge bg-success">Accepté</span>
                    {% elseif appointment.getStatus() == 'refused' %}
                        <span class="badge bg-danger">Refusé</span>
                    {% endif %}
                </p>
                <p><strong>Description:</strong><br/>{{ appointment.getDescription() ?: '-' }}</p>

                {% if appointment.getStatus() in ['completed', 'archived'] %}
                    <div class="mt-3 p-3 bg-light border rounded">
                        <p class="mb-2"><strong>Compte rendu:</strong></p>
                        {% if appointment.getReportName() %}
                            <div class="mb-2">
                                <a href="{{ vich_uploader_asset(appointment, 'reportFile') }}" class="btn btn-sm btn-outline-primary" download>
                                    <i class="fa fa-download me-1"></i>Telecharger
                                </a>
                                <span class="ms-2 text-muted small">{{ appointment.getReportName() }}</span>
                            </div>
                        {% else %}
                            <p class="text-muted mb-2">Aucun document televerse.</p>
                        {% endif %}
                        
                        {% if canUploadReport and reportForm is not null %}
                            <hr class="my-2">
                            <div class="mt-2">
                                <p class="small fw-bold mb-2">Televerser un nouveau compte rendu:</p>
                                {{ form_start(reportForm, {
                                    'attr': {'novalidate': 'novalidate'},
                                    'action': path('admin_rdv_report_upload', {'id': appointment.id})
                                }) }}
                                    <div class="mb-2">
                                        {{ form_widget(reportForm.reportFile, {'attr': {'class': 'form-control form-control-sm'}}) }}
                                        {% if reportForm.reportFile.vars.help %}
                                            <small class="form-text text-muted d-block mt-1">{{ reportForm.reportFile.vars.help }}</small>
                                        {% endif %}
                                        {{ form_errors(reportForm.reportFile) }}
                                    </div>
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="fa fa-upload me-1"></i>Televerser
                                    </button>
                                {{ form_end(reportForm) }}
                            </div>
                        {% endif %}
                    </div>
                {% endif %}

                {% if appointment.getZoomJoinUrl() %}
                    <p><strong>Lien Zoom:</strong><br/>
                        <a href="{{ appointment.getZoomJoinUrl() }}" target="_blank" class="btn btn-sm btn-primary">
                            <i class="fa fa-video me-1"></i>Rejoindre la réunion Zoom
                        </a>
                    </p>
                {% endif %}

                <div class="mt-4">
                    {% if appointment.getEtudiant() %}
                        <a href="{{ path('admin_patient_file_show', {'id': appointment.getEtudiant().getId()}) }}" class="btn btn-sm btn-info">
                            <i class="fa fa-file-medical me-1"></i>Dossier Médical
                        </a>
                    {% endif %}
                    
                    {% if is_granted('ROLE_PSYCHOLOGUE') and not is_granted('ROLE_ADMIN') %}
                        {% if appointment.getStatus() == 'pending' %}
                            <form method="POST" action="{{ path('admin_rdv_accept', {'id': appointment.getId()}) }}" style="display: inline;">
                                <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Accepter ce rendez-vous?')">Accepter</button>
                            </form>
                            <form method="POST" action="{{ path('admin_rdv_decline', {'id': appointment.getId()}) }}" style="display: inline;">
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Refuser ce rendez-vous?')">Refuser</button>
                            </form>
                        {% endif %}
                    {% else %}
                        <a href="{{ path('admin_rdv_edit', {'id': appointment.getId()}) }}" class="btn btn-sm btn-warning">Modifier</a>
                        <form method="post" action="{{ path('admin_rdv_delete', {'id': appointment.getId()}) }}" style="display:inline-block;" onsubmit="return confirm('Supprimer ce rendez-vous ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ appointment.getId()) }}">
                            <button class="btn btn-sm btn-danger">Supprimer</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>

        <a href="{% if is_granted('ROLE_PSYCHOLOGUE') and not is_granted('ROLE_ADMIN') %}{{ path('admin_rdv_pending') }}{% else %}{{ path('admin_rdv_index') }}{% endif %}" class="btn btn-link mt-3">Retour</a>
    </div>
{% endblock %}