{% extends 'admin/base_admin.html.twig' %}

{% block title %}Users List{% endblock %}
{% block page_title %}Users Management{% endblock %}

{% block body %}
<div class="card">
    <div class="card-header bg-light d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0 fw-bold">Users List</h5>
        <a href="{{ path('admin_users_new') }}" class="btn btn-primary btn-md px-3">
            <i class="fas fa-plus me-2"></i> Add New User
        </a>
    </div>
    
    <!-- Search and Filters Section -->
    <div class="card-body border-bottom">
        <form method="get" action="{{ path('admin_users_index') }}" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-bold">Search Users</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fas fa-search"></i>
                    </span>
                    <input type="text" 
                           name="search" 
                           class="form-control" 
                           placeholder="Search by name or email..."
                           value="{{ search }}">
                    {% if search %}
                        <a href="{{ path('admin_users_index') }}" class="input-group-text text-danger" title="Clear search">
                            <i class="fas fa-times"></i>
                        </a>
                    {% endif %}
                </div>
            </div>
            
            <div class="col-md-4">
                <label class="form-label fw-bold">Filter by Role</label>
                <div class="d-flex gap-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="roles[]" value="etudiant" id="role_etudiant"
                               {% if 'etudiant' in selected_roles %}checked{% endif %}>
                        <label class="form-check-label" for="role_etudiant">
                            Étudiant
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="roles[]" value="psychologue" id="role_psychologue"
                               {% if 'psychologue' in selected_roles %}checked{% endif %}>
                        <label class="form-check-label" for="role_psychologue">
                            Psychologue
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="roles[]" value="admin" id="role_admin"
                               {% if 'admin' in selected_roles %}checked{% endif %}>
                        <label class="form-check-label" for="role_admin">
                            Admin
                        </label>
                    </div>
                </div>
            </div>
            
            <div class="col-md-3">
                <label class="form-label fw-bold">Filter by Status</label>
                <select name="status" class="form-select">
                    <option value="all" {% if selected_status == 'all' %}selected{% endif %}>All Status</option>
                    <option value="active" {% if selected_status == 'active' %}selected{% endif %}>Active Only</option>
                    <option value="banned" {% if selected_status == 'banned' %}selected{% endif %}>Banned Only</option>
                </select>
            </div>
            
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-1"></i> Filter
                </button>
            </div>
        </form>
        
        <!-- Stats Bar - Only 2 boxes -->
        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card border-{{ stats.filter_color }} bg-{{ stats.filter_color }}-subtle shadow-sm">
                    <div class="card-body text-center py-4">
                        <h2 class="mb-2 text-{{ stats.filter_color }}">{{ stats.filtered }}</h2>
                        <small class="text-muted fw-medium">{{ stats.filter_type }}</small>
                        {% if search or selected_roles or selected_status != 'all' %}
                            <div class="mt-2">
                                <a href="{{ path('admin_users_index') }}" class="btn btn-sm btn-outline-{{ stats.filter_color }}">
                                    <i class="fas fa-times me-1"></i> Clear Filter
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-secondary bg-light shadow-sm">
                    <div class="card-body text-center py-4">
                        <h2 class="mb-2 text-secondary">{{ stats.total }}</h2>
                        <small class="text-muted fw-medium">Total Users in System</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Users Table -->
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 border-bottom">ID</th>
                        <th class="py-3 border-bottom">First Name</th>
                        <th class="py-3 border-bottom">Last Name</th>
                        <th class="py-3 border-bottom">Email</th>
                        <th class="py-3 border-bottom">Role</th>
                        <th class="text-center py-3 border-bottom">Status</th>
                        <th class="text-center py-3 border-bottom">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                    <tr>
                        <td class="ps-4 fw-bold">{{ user.id }}</td>
                        <td>{{ user.firstName }}</td>
                        <td>{{ user.lastName }}</td>
                        <td>{{ user.email }}</td>
                        <td>
                            <span class="badge 
                                {% if user.role == 'admin' %}bg-danger
                                {% elseif user.role == 'psychologue' %}bg-warning text-dark
                                {% else %}bg-info{% endif %}">
                                {{ user.role|upper }}
                            </span>
                        </td>
                        <td class="text-center">
                            {% if user.bannedUntil %}
                                {% set banDate = user.bannedUntil|date('Y-m-d') %}
                                {% set now = "now"|date('Y-m-d') %}
                                {% if banDate > now %}
                                    <span class="badge bg-danger">
                                        <i class="fas fa-ban me-1"></i> Banned until {{ banDate }}
                                    </span>
                                {% else %}
                                    <span class="badge bg-success">
                                        <i class="fas fa-check me-1"></i> Active
                                    </span>
                                {% endif %}
                            {% else %}
                                <span class="badge bg-success">
                                    <i class="fas fa-check me-1"></i> Active
                                </span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2 align-items-center">
                                <a href="{{ path('admin_users_edit', {'id': user.id}) }}" class="btn btn-warning btn-sm px-3">
                                    <i class="fas fa-edit me-1"></i> Edit
                                </a>

                                <form action="{{ path('admin_users_delete', {'id': user.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                    <button type="submit" class="btn btn-danger btn-sm px-3">
                                        <i class="fas fa-trash me-1"></i> Delete
                                    </button>
                                </form>

                                {# Ban/Unban button #}
                                <div class="ban-container d-inline-flex align-items-center">
                                    {% if user.bannedUntil and user.bannedUntil|date('Y-m-d') > "now"|date('Y-m-d') %}
                                        <form action="{{ path('admin_users_unban', {'id': user.id}) }}" method="post" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('unban' ~ user.id) }}">
                                            <button type="submit" class="btn btn-success btn-sm">
                                                <i class="fas fa-check me-1"></i> Unban
                                            </button>
                                        </form>
                                    {% else %}
                                        <button type="button" class="btn btn-dark btn-sm ban-btn" onclick="showBanCalendar(this)">
                                            <i class="fas fa-ban me-1"></i> Ban
                                        </button>
                                        <form action="{{ path('admin_users_ban', {'id': user.id}) }}" method="post" class="d-none ban-form" id="ban-form-{{ user.id }}" onsubmit="return validateBanDate(this)">
                                            <input type="hidden" name="_token" value="{{ csrf_token('ban' ~ user.id) }}">
                                            <div class="input-group input-group-sm" style="width: 250px;">
                                                <input type="date" name="banned_until" required
                                                       min="{{ "now"|date_modify('+1 day')|date('Y-m-d') }}"
                                                       class="form-control"
                                                       placeholder="Select ban date">
                                                <button type="submit" class="btn btn-dark">
                                                    <i class="fas fa-check"></i>
                                                </button>
                                                <button type="button" class="btn btn-outline-secondary" onclick="hideBanCalendar(this)">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </div>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <div class="text-muted">
                                <i class="fas fa-users fa-3x mb-3"></i>
                                <h5 class="fw-light">No users found</h5>
                                <p class="mb-0">
                                    {% if search or selected_roles or selected_status != 'all' %}
                                        Try changing your search criteria
                                    {% else %}
                                        Start by adding your first user
                                    {% endif %}
                                </p>
                                {% if search or selected_roles or selected_status != 'all' %}
                                    <a href="{{ path('admin_users_index') }}" class="btn btn-outline-primary btn-sm mt-2">
                                        <i class="fas fa-times me-1"></i> Clear filters
                                    </a>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function showBanCalendar(button) {
    // Hide the ban button
    button.classList.add('d-none');
    
    // Find and show the corresponding ban form
    const banContainer = button.closest('.ban-container');
    const banForm = banContainer.querySelector('.ban-form');
    
    if (banForm) {
        banForm.classList.remove('d-none');
        
        // Set tomorrow as minimum date
        const dateInput = banForm.querySelector('input[type="date"]');
        if (dateInput) {
            const tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);
            const tomorrowStr = tomorrow.toISOString().split('T')[0];
            dateInput.min = tomorrowStr;
            dateInput.value = tomorrowStr;
            dateInput.focus();
        }
    }
}

function hideBanCalendar(button) {
    // Find the ban container
    const banContainer = button.closest('.ban-container');
    const banForm = banContainer.querySelector('.ban-form');
    const banBtn = banContainer.querySelector('.ban-btn');
    
    // Hide form, show button
    banForm.classList.add('d-none');
    banBtn.classList.remove('d-none');
}

function validateBanDate(form) {
    const dateInput = form.querySelector('input[type="date"]');
    const selectedDate = new Date(dateInput.value);
    const today = new Date();
    
    // Set time to 00:00:00 for comparison
    today.setHours(0, 0, 0, 0);
    selectedDate.setHours(0, 0, 0, 0);
    
    if (selectedDate <= today) {
        alert('Please select a future date for the ban (at least tomorrow).');
        dateInput.focus();
        return false;
    }
    
    return true;
}

// Clear all filters
function clearFilters() {
    window.location.href = "{{ path('admin_users_index') }}";
}
</script>
{% endblock %}