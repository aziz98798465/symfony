<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Export Ressources</title>
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 12px;
            color: #1f2937;
        }

        .header {
            margin-bottom: 16px;
            border-bottom: 1px solid #d1d5db;
            padding-bottom: 10px;
        }

        .header h1 {
            margin: 0 0 4px 0;
            font-size: 20px;
        }

        .meta {
            color: #6b7280;
            font-size: 11px;
        }

        .stats {
            width: 100%;
            margin: 12px 0 16px;
            border-collapse: collapse;
        }

        .stats td {
            border: 1px solid #e5e7eb;
            padding: 8px;
            width: 16.6%;
        }

        .stats .label {
            font-size: 10px;
            color: #6b7280;
            text-transform: uppercase;
        }

        .stats .value {
            font-weight: 700;
            font-size: 14px;
            margin-top: 2px;
        }

        table.resources {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        table.resources th,
        table.resources td {
            border: 1px solid #e5e7eb;
            padding: 6px;
            vertical-align: top;
            word-wrap: break-word;
        }

        table.resources thead th {
            background: #f3f4f6;
            text-align: left;
        }

        .muted {
            color: #6b7280;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Export des ressources</h1>
        <div class="meta">
            Genere le {{ generated_at|date('Y-m-d H:i:s') }}
            | Filtre type: {{ filters.type == 'all' ? 'Tous' : filters.type|capitalize }}
            | Recherche: {{ filters.query is empty ? '-' : filters.query }}
        </div>
    </div>

    <table class="stats">
        <tr>
            <td>
                <div class="label">Ressources</div>
                <div class="value">{{ stats.totalResources }}</div>
            </td>
            <td>
                <div class="label">Videos</div>
                <div class="value">{{ stats.totalVideos }}</div>
            </td>
            <td>
                <div class="label">Articles</div>
                <div class="value">{{ stats.totalArticles }}</div>
            </td>
            <td>
                <div class="label">Commentaires</div>
                <div class="value">{{ stats.totalComments }}</div>
            </td>
            <td>
                <div class="label">Note moyenne</div>
                <div class="value">{{ stats.averageRating is not null ? stats.averageRating ~ ' / 5' : '-' }}</div>
            </td>
            <td>
                <div class="label">Lignes exportees</div>
                <div class="value">{{ rows|length }}</div>
            </td>
        </tr>
    </table>

    <table class="resources">
        <thead>
            <tr>
                <th style="width:5%">ID</th>
                <th style="width:18%">Titre</th>
                <th style="width:9%">Type</th>
                <th style="width:8%">Coms.</th>
                <th style="width:15%">Media</th>
                <th style="width:30%">Description</th>
                <th style="width:15%">Cree le</th>
            </tr>
        </thead>
        <tbody>
            {% for row in rows %}
                {% set resource = row.resource %}
                <tr>
                    <td>{{ resource.id }}</td>
                    <td>{{ resource.title }}</td>
                    <td>{{ resource.type|capitalize }}</td>
                    <td>{{ row.commentsCount }}</td>
                    <td>
                        {% if resource.type == 'video' and resource.videoUrl %}
                            {{ resource.videoUrl }}
                        {% elseif resource.type == 'article' and resource.imageUrl %}
                            {{ resource.imageUrl }}
                        {% elseif resource.filePath %}
                            {{ resource.filePath }}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>{{ resource.description }}</td>
                    <td>{{ resource.createdAt ? resource.createdAt|date('Y-m-d H:i') : '-' }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="muted">Aucune ressource trouvee pour ces filtres.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>
