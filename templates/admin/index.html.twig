{% extends 'admin/base_admin.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block page_title %}User Management Dashboard{% endblock %}

{% block body %}
    <style>
        .stat-card {
            border-left: 4px solid;
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
        }
        .stat-card.primary { border-left-color: #3498db; }
        .stat-card.success { border-left-color: #2ecc71; }
        .stat-card.warning { border-left-color: #f39c12; }
        .stat-card.danger { border-left-color: #e74c3c; }
        .stat-card.info { border-left-color: #1abc9c; }

        .chart-container {
            position: relative;
            height: 300px;
            margin-bottom: 30px;
        }

        .chart-container-line {
            position: relative;
            height: 350px;
            margin-bottom: 30px;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .chart-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .chart-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 15px;
            color: #2c3e50;
        }

        .card {
            border: none;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        .stat-value {
            font-size: 32px;
            font-weight: 700;
            color: #2c3e50;
        }

        .stat-label {
            font-size: 13px;
            color: #7f8c8d;
            text-transform: uppercase;
            font-weight: 600;
            margin-top: 5px;
        }
    </style>

    {# Top Statistics Row #}
    <div class="dashboard-grid">
        {# Total Users #}
        <div class="card stat-card primary">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-value">{{ statistics.totalUsers }}</div>
                        <div class="stat-label">Total Users</div>
                    </div>
                    <div class="avatar-text avatar-lg bg-primary bg-opacity-10">
                        <i class="feather-users"></i>
                    </div>
                </div>
            </div>
        </div>

        {# Verified Users #}
        <div class="card stat-card success">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-value">{{ statistics.verifiedUsers }}</div>
                        <div class="stat-label">Verified Users</div>
                    </div>
                    <div class="avatar-text avatar-lg bg-success bg-opacity-10">
                        <i class="feather-check-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        {# Unverified Users #}
        <div class="card stat-card warning">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-value">{{ statistics.unverifiedUsers }}</div>
                        <div class="stat-label">Unverified Users</div>
                    </div>
                    <div class="avatar-text avatar-lg bg-warning bg-opacity-10">
                        <i class="feather-alert-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        {# Banned Users #}
        <div class="card stat-card danger">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-value">{{ statistics.bannedUsers }}</div>
                        <div class="stat-label">Banned Users</div>
                    </div>
                    <div class="avatar-text avatar-lg bg-danger bg-opacity-10">
                        <i class="feather-lock"></i>
                    </div>
                </div>
            </div>
        </div>

        {# Active Users #}
        <div class="card stat-card info">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="stat-value">{{ statistics.activeUsers }}</div>
                        <div class="stat-label">Active Users</div>
                    </div>
                    <div class="avatar-text avatar-lg bg-info bg-opacity-10">
                        <i class="feather-activity"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Quick Navigation Buttons #}
    <div class="row mt-4 mb-4">
        <div class="col-12">
            <h5 style="margin-bottom: 15px; color: #333;">Quick Access</h5>
            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                <a href="{{ path('admin_moods') }}" class="btn btn-primary" style="background: #3498db; color: white; padding: 10px 20px; border: none; border-radius: 5px; text-decoration: none;">
                    <i class="feather-smile"></i> Moods
                </a>
                <a href="{{ path('admin_journals') }}" class="btn btn-info" style="background: #1abc9c; color: white; padding: 10px 20px; border: none; border-radius: 5px; text-decoration: none;">
                    <i class="feather-book"></i> Journals
                </a>
                <a href="{{ path('admin_patient_file_index') }}" class="btn btn-success" style="background: #2ecc71; color: white; padding: 10px 20px; border: none; border-radius: 5px; text-decoration: none;">
                    <i class="feather-file-text"></i> Patient Files
                </a>
                <a href="{{ path('sujet_forum_index') }}" class="btn btn-warning" style="background: #f39c12; color: white; padding: 10px 20px; border: none; border-radius: 5px; text-decoration: none;">
                    <i class="feather-message-circle"></i> Forum
                </a>
                <a href="{{ path('admin_psychological_alerts_index') }}" class="btn btn-danger" style="background: #e74c3c; color: white; padding: 10px 20px; border: none; border-radius: 5px; text-decoration: none; font-weight: bold;">
                    <i class="feather-alert-triangle"></i> 🚨 Alertes Psychologiques
                </a>
            </div>
        </div>
    </div>

    {# Charts Section #}
    <div class="row">
        {# Role Distribution Chart #}
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-body p-4">
                    <h5 class="chart-title">Users by Role</h5>
                    <div class="chart-container">
                        <canvas id="roleChart"></canvas>
                    </div>
                    <div class="d-flex justify-content-around text-center mt-3">
                        <div>
                            <span class="d-block fs-5 fw-bold">{{ statistics.totalStudents }}</span>
                            <small class="text-muted">Students</small>
                        </div>
                        <div>
                            <span class="d-block fs-5 fw-bold">{{ statistics.totalPsychologists }}</span>
                            <small class="text-muted">Psychologists</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Verification Status Chart #}
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-body p-4">
                    <h5 class="chart-title">Email Verification Status</h5>
                    <div class="chart-container">
                        <canvas id="verificationChart"></canvas>
                    </div>
                    <div class="d-flex justify-content-around text-center mt-3">
                        <div>
                            <span class="d-block fs-5 fw-bold text-success">{{ statistics.verifiedUsers }}</span>
                            <small class="text-muted">Verified</small>
                        </div>
                        <div>
                            <span class="d-block fs-5 fw-bold text-warning">{{ statistics.unverifiedUsers }}</span>
                            <small class="text-muted">Pending</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        {# User Status Chart #}
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-body p-4">
                    <h5 class="chart-title">Account Status</h5>
                    <div class="chart-container">
                        <canvas id="statusChart"></canvas>
                    </div>
                    <div class="d-flex justify-content-around text-center mt-3">
                        <div>
                            <span class="d-block fs-5 fw-bold text-info">{{ statistics.activeUsers }}</span>
                            <small class="text-muted">Active</small>
                        </div>
                        <div>
                            <span class="d-block fs-5 fw-bold text-danger">{{ statistics.bannedUsers }}</span>
                            <small class="text-muted">Banned</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Registration Trend Chart #}
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-body p-4">
                    <h5 class="chart-title">Registration Trend (Last 12 Months)</h5>
                    <div class="chart-container-line">
                        <canvas id="trendChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <script>
        const chartData = {{ chartData|raw }};

        // Role Distribution Chart (Pie)
        const roleCtx = document.getElementById('roleChart').getContext('2d');
        new Chart(roleCtx, {
            type: 'doughnut',
            data: {
                labels: chartData.roleDistribution.labels,
                datasets: [{
                    data: chartData.roleDistribution.data,
                    backgroundColor: chartData.roleDistribution.backgroundColor,
                    borderColor: chartData.roleDistribution.borderColor,
                    borderWidth: 2,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 15,
                            font: { size: 12, weight: 'bold' }
                        }
                    }
                }
            }
        });

        // Verification Status Chart (Donut)
        const verificationCtx = document.getElementById('verificationChart').getContext('2d');
        new Chart(verificationCtx, {
            type: 'doughnut',
            data: {
                labels: chartData.verificationStatus.labels,
                datasets: [{
                    data: chartData.verificationStatus.data,
                    backgroundColor: chartData.verificationStatus.backgroundColor,
                    borderColor: chartData.verificationStatus.borderColor,
                    borderWidth: 2,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 15,
                            font: { size: 12, weight: 'bold' }
                        }
                    }
                }
            }
        });

        // User Status Chart (Pie)
        const statusCtx = document.getElementById('statusChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: chartData.userStatus.labels,
                datasets: [{
                    data: chartData.userStatus.data,
                    backgroundColor: chartData.userStatus.backgroundColor,
                    borderColor: chartData.userStatus.borderColor,
                    borderWidth: 2,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 15,
                            font: { size: 12, weight: 'bold' }
                        }
                    }
                }
            }
        });

        // Registration Trend Chart (Line)
        const trendCtx = document.getElementById('trendChart').getContext('2d');
        new Chart(trendCtx, {
            type: 'line',
            data: {
                labels: chartData.registrationTrend.labels,
                datasets: [{
                    label: 'New Registrations',
                    data: chartData.registrationTrend.data,
                    borderColor: chartData.registrationTrend.borderColor,
                    backgroundColor: chartData.registrationTrend.backgroundColor,
                    borderWidth: 3,
                    fill: true,
                    tension: chartData.registrationTrend.tension,
                    pointRadius: 5,
                    pointBackgroundColor: '#3498db',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointHoverRadius: 7,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        labels: {
                            font: { size: 12, weight: 'bold' }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                }
            }
        });
    </script>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="assets/js/dashboard-init.min.js"></script>
{% endblock %}