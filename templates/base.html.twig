<!doctype html>
<html class="no-js" lang="zxx">

<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>{% block title %}MindCare{% endblock %}</title>
    <base href="{{ asset('front/') }}">
    <meta name="description" content="">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="shortcut icon" type="image/x-icon" href="{{ asset('front/img/favicon.png') }}">
    {% if ga4_measurement_id is not empty %}
        <script async src="https://www.googletagmanager.com/gtag/js?id={{ ga4_measurement_id }}"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '{{ ga4_measurement_id|e('js') }}', {
                'page_path': '{{ app.request.pathInfo|e('js') }}'
            });
        </script>
    {% endif %}

    {% block stylesheets %}
        {% if app.request.attributes.get('_route') in ['app_login', 'app_register', 'app_forgot_password', 'app_verify_code', 'app_reset_password'] %}
            {# Login/signup specific CSS #}
            <link rel="stylesheet" href="{{ asset('front/css/bootstrap.min.css') }}">
            <link rel="stylesheet" href="{{ asset('front/css/login.css') }}">
        {% else %}
            {# Full front site CSS #}
            <link rel="stylesheet" href="{{ asset('front/css/bootstrap.min.css') }}">
            <link rel="stylesheet" href="{{ asset('front/css/owl.carousel.min.css') }}">
            <link rel="stylesheet" href="{{ asset('front/css/magnific-popup.css') }}">
            <link rel="stylesheet" href="{{ asset('front/css/font-awesome.min.css') }}">
            <link rel="stylesheet" href="{{ asset('front/css/themify-icons.css') }}">
            <link rel="stylesheet" href="{{ asset('front/css/nice-select.css') }}">
            <link rel="stylesheet" href="{{ asset('front/css/flaticon.css') }}">
            <link rel="stylesheet" href="{{ asset('front/css/gijgo.css') }}">
            <link rel="stylesheet" href="{{ asset('front/css/animate.css') }}">
            <link rel="stylesheet" href="{{ asset('front/css/slicknav.css') }}">
            <link rel="stylesheet" href="{{ asset('front/css/style.css') }}">
        {% endif %}

        {# Banned Popup Styles (always needed) #}
        <style>
            .banned-popup {
                position: fixed;
                top: 20px;
                right: 20px;
                background-color: #f8d7da;
                color: #721c24;
                border: 1px solid #f5c6cb;
                border-radius: 8px;
                padding: 15px 20px;
                z-index: 9999;
                box-shadow: 0 4px 8px rgba(0,0,0,0.2);
                animation: slideIn 0.5s ease forwards;
                max-width: 300px;
            }
            .banned-popup h3 { margin:0 0 5px 0; font-size:16px; }
            .banned-popup p { margin:0 0 10px 0; font-size:14px; }
            .banned-popup button {
                background-color: #721c24;
                color: white;
                border: none;
                padding: 5px 10px;
                border-radius: 5px;
                cursor: pointer;
            }
            @keyframes slideIn {
                from { opacity: 0; transform: translateX(100%); }
                to { opacity: 1; transform: translateX(0); }
            }
            .banned-popup.fade-out { animation: fadeOut 0.5s forwards; }
            @keyframes fadeOut {
                from { opacity: 1; transform: translateX(0); }
                to { opacity: 0; transform: translateX(100%); }
            }
        </style>
    {% endblock %}
</head>

<body class="{% if app.request.attributes.get('_route') in ['app_login', 'app_register', 'app_forgot_password', 'app_verify_code', 'app_reset_password'] %}auth-page{% endif %}">

    {# HEADER - show only for home / non-auth pages #}
    {% if app.request.attributes.get('_route') not in ['app_login', 'app_register', 'app_forgot_password', 'app_verify_code', 'app_reset_password'] %}
        {% include 'front/partials/header.html.twig' %}
    {% endif %}

    {# MAIN CONTENT #}
    {% block body %}{% endblock %}

    {# FOOTER - show only for home / non-auth pages #}
    {% if app.request.attributes.get('_route') not in ['app_login', 'app_register', 'app_forgot_password', 'app_verify_code', 'app_reset_password'] %}
        {% include 'front/partials/footer.html.twig' %}
    {% endif %}

    {# Banned Popup Flash #}
    {% for message in app.flashes('banned') %}
        <div id="banned-popup" class="banned-popup">
            <h3>⚠️ Compte banni !</h3>
            <p>Votre compte est banni jusqu'au <strong>{{ message }}</strong>.</p>
            <button id="close-banned-popup">Fermer</button>
        </div>
    {% endfor %}

    {% block javascripts %}
        {% if app.request.attributes.get('_route') in ['app_login', 'app_register', 'app_forgot_password', 'app_verify_code', 'app_reset_password'] %}
            {# Login/signup JS #}
            <script src="{{ asset('front/js/vendor/modernizr-3.5.0.min.js') }}"></script>
            <script src="{{ asset('front/js/vendor/jquery-1.12.4.min.js') }}"></script>
            <script src="{{ asset('front/js/popper.min.js') }}"></script>
            <script src="{{ asset('front/js/bootstrap.min.js') }}"></script>
            <script src="{{ asset('front/js/login.js') }}"></script>
            <script src="https://www.google.com/recaptcha/api.js" async defer></script>
        {% else %}
            {# Full front site JS #}
            <script src="{{ asset('front/js/vendor/modernizr-3.5.0.min.js') }}"></script>
            <script src="{{ asset('front/js/vendor/jquery-1.12.4.min.js') }}"></script>
            <script src="{{ asset('front/js/popper.min.js') }}"></script>
            <script src="{{ asset('front/js/bootstrap.min.js') }}"></script>
            <script src="{{ asset('front/js/owl.carousel.min.js') }}"></script>
            <script src="{{ asset('front/js/isotope.pkgd.min.js') }}"></script>
            <script src="{{ asset('front/js/ajax-form.js') }}"></script>
            <script src="{{ asset('front/js/waypoints.min.js') }}"></script>
            <script src="{{ asset('front/js/jquery.counterup.min.js') }}"></script>
            <script src="{{ asset('front/js/imagesloaded.pkgd.min.js') }}"></script>
            <script src="{{ asset('front/js/scrollIt.js') }}"></script>
            <script src="{{ asset('front/js/jquery.scrollUp.min.js') }}"></script>
            <script src="{{ asset('front/js/wow.min.js') }}"></script>
            <script src="{{ asset('front/js/nice-select.min.js') }}"></script>
            <script src="{{ asset('front/js/jquery.slicknav.min.js') }}"></script>
            <script src="{{ asset('front/js/jquery.magnific-popup.min.js') }}"></script>
            <script src="{{ asset('front/js/plugins.js') }}"></script>
            <script src="{{ asset('front/js/gijgo.min.js') }}"></script>
            <script src="{{ asset('front/js/contact.js') }}"></script>
            <script src="{{ asset('front/js/jquery.ajaxchimp.min.js') }}"></script>
            <script src="{{ asset('front/js/jquery.form.js') }}"></script>
            <script src="{{ asset('front/js/jquery.validate.min.js') }}"></script>
            <script src="{{ asset('front/js/mail-script.js') }}"></script>
            <script src="{{ asset('front/js/main.js') }}"></script>
        {% endif %}

        {# Banned Popup Script #}
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const popup = document.getElementById('banned-popup');
                const closeBtn = document.getElementById('close-banned-popup');
                if (popup && closeBtn) {
                    const hidePopup = () => {
                        popup.classList.add('fade-out');
                        setTimeout(() => popup.style.display = 'none', 500);
                    };
                    closeBtn.addEventListener('click', hidePopup);
                    setTimeout(hidePopup, 10000); // auto-hide after 10 seconds
                }
            });
        </script>
    {% endblock %}

</body>
</html>
