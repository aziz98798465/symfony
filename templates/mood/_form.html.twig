<div class="card shadow-sm mb-4" style="border: 1px solid #D4E8FF; border-radius: 12px; box-shadow: 0 4px 12px rgba(127, 191, 255, 0.15);">
    <div class="card-body">
        <h5 class="card-title mb-4" style="color: #1a365d; font-weight: 700;">
            <i class="fas fa-smile me-2" style="color: #7FBFFF;"></i>Votre Humeur du Jour
        </h5>

        {% if form.vars.errors|length > 0 %}
            <div class="alert alert-danger" role="alert">
                <h6 class="alert-heading"><i class="fas fa-exclamation-circle me-2"></i>Erreurs de validation</h6>
                <ul class="mb-0">
                    {% for error in form.vars.errors %}
                        <li>{{ error.message }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
        
        <div class="row">
            <div class="col-md-8">
                <div class="form-group mb-4">
                    {{ form_label(form.humeur, null, {label_attr: {class: 'form-label fw-bold'}}) }}
                    {{ form_widget(form.humeur) }}
                    {% if form.humeur.vars.errors|length > 0 %}
                        <div class="invalid-feedback d-block">
                            {% for error in form.humeur.vars.errors %}
                                {{ error.message }}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
                
                <div class="form-group mb-4">
                    {{ form_label(form.intensite, null, {label_attr: {class: 'form-label fw-bold'}}) }}
                    <div class="mt-2">
                        {{ form_widget(form.intensite, {'attr': {'style': 'accent-color: #7FBFFF;', 'min': 1, 'max': 5, 'step': 1}}) }}
                        <div class="d-flex justify-content-between mt-1">
                            <small style="color: #718096;">Faible</small>
                            <small style="color: #718096;">Moyenne</small>
                            <small style="color: #718096;">Forte</small>
                        </div>
                    </div>
                    {% if form.intensite.vars.errors|length > 0 %}
                        <div class="invalid-feedback d-block">
                            {% for error in form.intensite.vars.errors %}
                                {{ error.message }}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
                
                <div class="form-group mb-4">
                    {{ form_label(form.datemood, null, {label_attr: {class: 'form-label fw-bold'}}) }}
                    {{ form_widget(form.datemood) }}
                    {% if form.datemood.vars.errors|length > 0 %}
                        <div class="invalid-feedback d-block">
                            {% for error in form.datemood.vars.errors %}
                                {{ error.message }}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card" style="background: linear-gradient(135deg, rgba(127, 191, 255, 0.08) 0%, rgba(168, 216, 255, 0.08) 100%); border: 1px solid #D4E8FF; border-radius: 12px;">
                    <div class="card-body text-center">
                        <div class="mb-3">
                            <div id="moodPreview" class="display-1">😊</div>
                        </div>
                        <h6 id="moodText" style="color: #1a365d; font-weight: 600;">Heureux(euse)</h6>
                        <div class="mt-3">
                            <div class="progress" style="height: 20px; background-color: #E8F0FF; border-radius: 10px;">
                                <div id="intensityBar" class="progress-bar" style="width: 60%; background: linear-gradient(90deg, #7FBFFF 0%, #A8D8FF 100%);">3/5</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control, .form-select {
        border: 1px solid #D4E8FF;
        border-radius: 8px;
    }

    .form-control:focus, .form-select:focus {
        border-color: #7FBFFF;
        box-shadow: 0 0 0 0.2rem rgba(127, 191, 255, 0.25);
    }

    .form-label {
        color: #1a365d;
    }

    .invalid-feedback {
        color: #e53e3e;
        font-size: 0.85rem;
        margin-top: 0.25rem;
    }

    .mood-choices {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .mood-choices input[type="radio"] {
        margin-right: 0.5rem;
    }
</style>