{% extends 'base.html.twig' %}

{% block body %}
<div class="wrapper">
    <div class="title-text">
        <div class="title login">Verify Account</div>
    </div>

    <div class="form-container">
        <div class="form-inner" style="width: 100%;">
            <form method="post" action="{{ path('app_resend_verification') }}" class="login" style="width: 100%;">
                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger">{{ message }}</div>
                {% endfor %}

                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">{{ message }}</div>
                {% endfor %}

                <div class="field">
                    <input type="email" name="email" placeholder="Email Address" required>
                </div>

                <div class="field btn">
                    <div class="btn-layer"></div>
                    <input type="submit" value="Send Verification Email">
                </div>

                <div class="forgot-link-container">
                    <a href="{{ path('app_login') }}" class="forgot-link">Back to Login</a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
