{% extends 'base.html.twig' %}

{% block body %}
<div class="wrapper" style="padding: 30px;">
    <div class="title-text" style="width: 100%; margin-bottom: 20px;">
        <div class="title" style="width: 100%; font-size: 28px;">Reset Password</div>
    </div>
    
    <div class="form-container">
        <div style="margin-bottom: 25px; text-align: center; color: #666; font-size: 14px;">
            Enter your new password below
        </div>
        
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}
        
        <form method="post" action="{{ path('app_reset_password') }}">
            <div class="field">
                <input type="password" name="password" placeholder="New Password" required autofocus>
            </div>
            
            <div class="field">
                <input type="password" name="confirmPassword" placeholder="Confirm Password" required>
            </div>
            
            <div style="font-size: 12px; color: #666; margin-top: 5px; padding-left: 5px;">
                Password must be at least 6 characters
            </div>
            
            <div class="field btn">
                <div class="btn-layer"></div>
                <input type="submit" value="Reset Password">
            </div>
            
            <div class="back-link" style="margin-top: 20px;">
                <a href="{{ path('app_login') }}">← Back to Login</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}