{% extends 'base.html.twig' %}

{% block title %}{{ event.titre }}{% endblock %}

{% block body %}
    <style>
        /* Light Blue Theme - Bleu Ciel */
        :root {
            --color-sky-light: #e0f2fe;
            --color-sky-medium: #7dd3fc;
            --color-sky-dark: #0284c7;
            --color-sky-darker: #0369a1;
        }

        .event-detail-hero {
            background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 50%, #06b6d4 100%);
            padding: 80px 0;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .event-detail-hero::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            border-radius: 50%;
            transform: translate(100px, -50px);
        }

        .event-detail-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(2, 132, 199, 0.15);
            padding: 40px;
            margin-top: -50px;
            border: 1px solid #cffafe;
            position: relative;
            z-index: 1;
        }

        .event-detail-meta {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .event-detail-meta span {
            background: linear-gradient(135deg, #e0f2fe 0%, #cffafe 100%);
            padding: 10px 18px;
            border-radius: 12px;
            font-size: 15px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #0284c7;
            font-weight: 500;
            border: 1px solid #bae6fd;
        }

        .event-action-card {
            background: linear-gradient(135deg, #e0f2fe 0%, #cffafe 100%);
            border: 2px solid #7dd3fc;
            border-radius: 16px;
            padding: 32px;
            box-shadow: 0 4px 20px rgba(2, 132, 199, 0.12);
        }

        .event-cta {
            background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%);
            color: white;
            padding: 14px 32px;
            border-radius: 12px;
            border: none;
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 100%;
            box-shadow: 0 4px 15px rgba(2, 132, 199, 0.3);
        }

        .event-cta:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(2, 132, 199, 0.35);
            background: linear-gradient(135deg, #0369a1 0%, #0284c7 100%);
        }

        .event-cta:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            background: linear-gradient(135deg, #c7d2e0 0%, #cbd5e1 100%);
        }

        .event-badge {
            padding: 8px 16px;
            border-radius: 12px;
            font-size: 13px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .badge-open {
            background: linear-gradient(135deg, rgba(2, 132, 199, 0.15) 0%, rgba(7, 165, 233, 0.15) 100%);
            color: #0369a1;
        }

        .badge-full {
            background: rgba(239, 68, 68, 0.15);
            color: #b91c1c;
        }

        .badge-pending {
            background: rgba(245, 158, 11, 0.15);
            color: #b45309;
        }

        .badge-accepted {
            background: rgba(34, 197, 94, 0.15);
            color: #15803d;
        }

        .badge-refused {
            background: rgba(239, 68, 68, 0.15);
            color: #b91c1c;
        }

        .badge-cancelled {
            background: rgba(100, 116, 139, 0.2);
            color: #334155;
        }

        .countdown-box {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 12px;
            padding: 16px 20px;
            text-align: center;
            min-width: 80px;
            transition: transform 0.3s;
        }

        .countdown-box:hover {
            transform: translateY(-4px);
            background: rgba(255, 255, 255, 0.22);
        }

        .countdown-value {
            display: block;
            font-size: 32px;
            font-weight: 800;
            color: white;
            line-height: 1;
        }

        .countdown-label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.8);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 6px;
        }

        /* ===== Chatbot Floating Widget ===== */
        .chatbot-toggle {
            position: fixed;
            bottom: 28px;
            right: 28px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%);
            color: white;
            border: none;
            cursor: pointer;
            box-shadow: 0 6px 24px rgba(2, 132, 199, 0.45);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            z-index: 10000;
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .chatbot-toggle:hover {
            transform: scale(1.1);
            box-shadow: 0 8px 32px rgba(2, 132, 199, 0.55);
        }
        .chatbot-toggle .badge-dot {
            position: absolute;
            top: 4px;
            right: 4px;
            width: 14px;
            height: 14px;
            background: #22c55e;
            border-radius: 50%;
            border: 2px solid white;
        }

        .chatbot-window {
            position: fixed;
            bottom: 100px;
            right: 28px;
            width: 380px;
            max-height: 520px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 12px 48px rgba(2, 132, 199, 0.25);
            z-index: 10001;
            display: none;
            flex-direction: column;
            overflow: hidden;
            border: 1px solid #bae6fd;
            animation: chatSlideUp 0.3s ease;
        }
        .chatbot-window.open {
            display: flex;
        }
        @keyframes chatSlideUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .chatbot-header {
            background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%);
            color: white;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .chatbot-header-avatar {
            width: 38px;
            height: 38px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }
        .chatbot-header-info h4 {
            margin: 0;
            font-size: 15px;
            font-weight: 700;
        }
        .chatbot-header-info span {
            font-size: 11px;
            opacity: 0.85;
        }
        .chatbot-close {
            margin-left: auto;
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }
        .chatbot-close:hover {
            background: rgba(255,255,255,0.35);
        }

        .chatbot-messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            max-height: 320px;
            background: #f8fafc;
        }
        .chatbot-messages::-webkit-scrollbar { width: 5px; }
        .chatbot-messages::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }

        .chat-msg {
            max-width: 82%;
            padding: 12px 16px;
            border-radius: 16px;
            font-size: 13.5px;
            line-height: 1.55;
            word-wrap: break-word;
        }
        .chat-msg.bot {
            align-self: flex-start;
            background: white;
            color: #334155;
            border: 1px solid #e2e8f0;
            border-bottom-left-radius: 4px;
        }
        .chat-msg.user {
            align-self: flex-end;
            background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%);
            color: white;
            border-bottom-right-radius: 4px;
        }
        .chat-msg.bot .msg-label {
            font-size: 10px;
            font-weight: 600;
            color: #0284c7;
            margin-bottom: 4px;
        }
        .chat-msg.user .msg-label {
            font-size: 10px;
            font-weight: 600;
            color: rgba(255,255,255,0.7);
            margin-bottom: 4px;
            text-align: right;
        }

        .chat-typing {
            align-self: flex-start;
            display: flex;
            gap: 5px;
            padding: 12px 18px;
            background: white;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
        }
        .chat-typing span {
            width: 8px;
            height: 8px;
            background: #94a3b8;
            border-radius: 50%;
            animation: typingDot 1.4s infinite;
        }
        .chat-typing span:nth-child(2) { animation-delay: 0.2s; }
        .chat-typing span:nth-child(3) { animation-delay: 0.4s; }
        @keyframes typingDot {
            0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
            30% { transform: translateY(-6px); opacity: 1; }
        }

        .chatbot-input-area {
            padding: 14px 16px;
            border-top: 1px solid #e2e8f0;
            display: flex;
            gap: 10px;
            background: white;
        }
        .chatbot-input-area input {
            flex: 1;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 10px 14px;
            font-size: 13.5px;
            outline: none;
            transition: border-color 0.2s;
        }
        .chatbot-input-area input:focus {
            border-color: #0ea5e9;
        }
        .chatbot-input-area button {
            background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 10px 16px;
            cursor: pointer;
            font-size: 16px;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .chatbot-input-area button:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 12px rgba(2, 132, 199, 0.3);
        }
        .chatbot-input-area button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .chatbot-suggestions {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            padding: 0 16px 12px 16px;
            background: #f8fafc;
        }
        .chatbot-suggestions button {
            background: white;
            border: 1px solid #bae6fd;
            border-radius: 20px;
            padding: 6px 14px;
            font-size: 12px;
            color: #0284c7;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.2s;
        }
        .chatbot-suggestions button:hover {
            background: #e0f2fe;
            border-color: #0284c7;
        }
    </style>

    <div class="event-detail-hero">
        {% if event.image %}
            <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(135deg, rgba(2, 132, 199, 0.7) 0%, rgba(10, 165, 233, 0.7) 100%), url('{{ asset(event.image) }}'); background-size: cover; background-position: center; z-index: 0;"></div>
        {% endif %}
        <div class="container" style="position: relative; z-index: 1;">
            <h1 style="font-size: 48px; font-weight: 800; margin-bottom: 20px; letter-spacing: -1px;">{{ event.titre }}</h1>
            <div class="event-detail-meta">
                <span><i class="ti-calendar"></i> {{ event.dateEvent|date('d M Y, H:i') }}</span>
                <span><i class="ti-location-pin"></i> {{ event.lieu }}</span>
                <span><i class="ti-user"></i> Capacité: {{ event.capacite }}</span>
            </div>

            <!-- Countdown Timer -->
            <div id="countdown-container" style="margin-top: 28px;">
                <div style="display: flex; gap: 16px; justify-content: flex-start; flex-wrap: wrap;" id="countdown-boxes">
                    <div class="countdown-box">
                        <span id="cd-days" class="countdown-value">--</span>
                        <span class="countdown-label">Jours</span>
                    </div>
                    <div class="countdown-box">
                        <span id="cd-hours" class="countdown-value">--</span>
                        <span class="countdown-label">Heures</span>
                    </div>
                    <div class="countdown-box">
                        <span id="cd-minutes" class="countdown-value">--</span>
                        <span class="countdown-label">Minutes</span>
                    </div>
                    <div class="countdown-box">
                        <span id="cd-seconds" class="countdown-value">--</span>
                        <span class="countdown-label">Secondes</span>
                    </div>
                </div>
                <p id="cd-past" style="display: none; color: rgba(255,255,255,0.9); font-weight: 600; font-size: 16px; margin-top: 12px; background: rgba(255,255,255,0.15); padding: 8px 20px; border-radius: 10px;">
                    Cet événement a déjà commencé
                </p>
            </div>
        </div>
    </div>

    <div class="container" style="padding: 80px 20px;">
        <!-- Calendar Section -->
        <div style="background: linear-gradient(135deg, #f8fafc 0%, #e0f2fe 100%); border-radius: 16px; padding: 40px; margin-bottom: 40px; border: 1px solid #bae6fd;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; flex-wrap: wrap; gap: 16px;">
                <h3 style="font-weight: 800; color: #1e3a8a; font-size: 24px; margin: 0;">Vérifiez les disponibilités</h3>
                <button id="openCalendarBtn" style="background: linear-gradient(135deg, #3b82f6 0%, #0ea5e9 100%); color: white; border: none; padding: 10px 20px; border-radius: 25px; font-weight: 600; cursor: pointer; transition: all 0.3s; font-size: 14px; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(3, 105, 161, 0.2);">
                    <i class="ti-calendar"></i>
                    <span>Plus de dates</span>
                </button>
            </div>

            <!-- Quick Dates Preview -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 12px; margin-bottom: 20px;">
                {% set displayedDates = 0 %}
                {% for dateKey, data in calendarData %}
                    {% if displayedDates < 10 and data.events > 0 %}
                        {% set availabilityPercent = (data.available / data.total * 100)|round %}
                        {% if availabilityPercent > 50 %}
                            {% set badgeColor = '#06b6d4' %}
                            {% set badgeBg = 'rgba(6, 182, 212, 0.1)' %}
                            {% set badgeText = 'Plupart dispo' %}
                        {% else %}
                            {% set badgeColor = '#f59e0b' %}
                            {% set badgeBg = 'rgba(245, 158, 11, 0.1)' %}
                            {% set badgeText = 'Peu d\'options' %}
                        {% endif %}
                        <div style="background: white; border: 2px solid {{ badgeColor }}; border-radius: 12px; padding: 16px; text-align: center; transition: all 0.3s; cursor: pointer;"
                             onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 24px rgba(3, 105, 161, 0.2)'"
                             onmouseout="this.style.transform='none'; this.style.boxShadow='none'">
                            <div style="text-align: uppercase; font-size: 10px; color: #64748b; font-weight: 600; letter-spacing: 0.5px; margin-bottom: 6px;">{{ data.date|date('D') }}</div>
                            <div style="font-size: 24px; font-weight: 800; color: #1e3a8a; margin-bottom: 6px;">{{ data.date|date('d') }}</div>
                            <div style="font-size: 10px; color: #64748b; font-weight: 500; margin-bottom: 8px;">{{ data.date|date('b Y') }}</div>
                            <div style="background: {{ badgeBg }}; color: {{ badgeColor }}; padding: 5px 8px; border-radius: 8px; font-size: 10px; font-weight: 600;">{{ data.available }}/{{ data.total }}</div>
                        </div>
                        {% set displayedDates = displayedDates + 1 %}
                    {% endif %}
                {% endfor %}
            </div>

            <div style="text-align: center; color: #0284c7; font-size: 13px; font-weight: 600; padding-top: 12px; border-top: 1px solid #bae6fd;">
                <i class="ti-info-alt"></i> {{ calendarData|length }} dates disponibles
            </div>
        </div>

        <!-- Calendar Modal -->
        <div id="calendarModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.7); z-index: 9999; justify-content: center; align-items: center; padding: 20px; overflow-y: auto;">
            <div style="background: white; border-radius: 20px; max-width: 1000px; width: 100%; margin: auto; padding: 40px; position: relative;">
                <button id="closeCalendarBtn" style="position: absolute; top: 20px; right: 20px; background: #f1f5f9; border: none; font-size: 24px; cursor: pointer; color: #64748b; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 10px; transition: all 0.3s;"
                        onmouseover="this.style.background='#e2e8f0'; this.style.color='#334155'"
                        onmouseout="this.style.background='#f1f5f9'; this.style.color='#64748b'">
                    <i class="ti-close"></i>
                </button>

                <h2 style="font-weight: 800; color: #1e3a8a; margin-bottom: 32px; text-align: center; font-size: 28px;">Sélectionnez une date</h2>

                <!-- Two-Month View -->
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px; margin-bottom: 30px;">
                    {% set currentMonth = startDate %}
                    {% for monthIndex in 0..1 %}
                        <div>
                            <h4 style="font-weight: 700; color: #1e40af; text-align: center; margin-bottom: 24px; font-size: 18px;">{{ currentMonth|date('F Y')|capitalize }}</h4>

                            <!-- Weekday Headers -->
                            <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; margin-bottom: 12px;">
                                {% for weekday in ['L', 'M', 'M', 'J', 'V', 'S', 'D'] %}
                                    <div style="text-align: center; font-weight: 600; color: #64748b; font-size: 12px; text-transform: uppercase; padding: 8px 0;">{{ weekday }}</div>
                                {% endfor %}
                            </div>

                            <!-- Calendar Days -->
                            <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px;">
                                {% set firstDay = currentMonth|date('w') + 0 %}
                                {% set daysInMonth = currentMonth|date('t') + 0 %}
                                
                                {% for i in 1..firstDay %}
                                    <div></div>
                                {% endfor %}

                                {% for day in 1..daysInMonth %}
                                    {% set dateStr = currentMonth|date('Y-m-') ~ (day < 10 ? '0' : '') ~ day %}
                                    
                                    {% if dateStr in calendarData %}
                                        {% set data = calendarData[dateStr] %}
                                        {% set availabilityPercent = (data.available / data.total * 100)|round %}
                                        {% if availabilityPercent > 50 %}
                                            {% set dayBorder = '#06b6d4' %}
                                            {% set dayBg = 'rgba(6, 182, 212, 0.1)' %}
                                            {% set dayColor = '#0369a1' %}
                                        {% else %}
                                            {% set dayBorder = '#f59e0b' %}
                                            {% set dayBg = 'rgba(245, 158, 11, 0.1)' %}
                                            {% set dayColor = '#b45309' %}
                                        {% endif %}
                                        <div style="background: {{ dayBg }}; border: 2px solid {{ dayBorder }}; border-radius: 8px; padding: 12px 8px; text-align: center; cursor: pointer; transition: all 0.3s ease; position: relative;"
                                             onmouseover="this.style.transform='scale(1.05)'; this.style.boxShadow='0 4px 12px rgba(3, 105, 161, 0.2)'; this.style.borderColor='#0284c7'"
                                             onmouseout="this.style.transform='none'; this.style.boxShadow='none'">
                                            <div style="font-weight: 700; color: #1e3a8a; font-size: 16px;">{{ day }}</div>
                                            <div style="font-size: 9px; color: {{ dayColor }}; font-weight: 600; margin-top: 4px;">{{ data.available }}/{{ data.total }}</div>
                                        </div>
                                    {% else %}
                                        <div style="color: #cbd5e1; text-align: center; padding: 12px 8px; font-weight: 500; font-size: 12px;">{{ day }}</div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                        {% set currentMonth = endDate %}
                    {% endfor %}
                </div>

                <!-- Legend -->
                <div style="background: linear-gradient(135deg, #f0f9ff 0%, #f0f4f8 100%); border-radius: 14px; padding: 24px; display: flex; gap: 32px; justify-content: center; flex-wrap: wrap; border: 1px solid #bae6fd;">
                    <div style="display: flex; align-items: center; gap: 12px; font-size: 14px; font-weight: 500; color: #475569;">
                        <div style="width: 24px; height: 24px; background: rgba(245, 158, 11, 0.15); border: 2px solid #f59e0b; border-radius: 6px;"></div>
                        <span>Peu d'options disponibles</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 12px; font-size: 14px; font-weight: 500; color: #475569;">
                        <div style="width: 24px; height: 24px; background: rgba(6, 182, 212, 0.15); border: 2px solid #06b6d4; border-radius: 6px;"></div>
                        <span>Les options sont disponibles</span>
                    </div>
                </div>
            </div>
        </div>

        <script>
            const calendarModal = document.getElementById('calendarModal');
            const openBtn = document.getElementById('openCalendarBtn');
            const closeBtn = document.getElementById('closeCalendarBtn');

            openBtn.addEventListener('click', () => {
                calendarModal.style.display = 'flex';
            });

            closeBtn.addEventListener('click', () => {
                calendarModal.style.display = 'none';
            });

            calendarModal.addEventListener('click', (e) => {
                if (e.target === calendarModal) {
                    calendarModal.style.display = 'none';
                }
            });
        </script>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="event-detail-card">
                    <h3 style="font-weight: 800; margin-bottom: 20px; color: #1e3a8a; font-size: 24px;">Description</h3>
                    <p style="color: #475569; line-height: 1.8; font-size: 16px; margin: 0;">{{ event.description }}</p>
                </div>

                <!-- OpenStreetMap Location -->
                <div class="event-detail-card" style="margin-top: 24px;">
                    <h3 style="font-weight: 800; margin-bottom: 20px; color: #1e3a8a; font-size: 24px;">
                        <i class="ti-location-pin" style="color: #0284c7;"></i> Localisation
                    </h3>
                    <p style="color: #475569; font-size: 15px; margin-bottom: 16px;">
                        <i class="ti-map-alt" style="color: #0284c7; margin-right: 6px;"></i>
                        {{ event.lieu }}
                    </p>
                    <div id="eventMap" style="height: 350px; border-radius: 12px; border: 2px solid #bae6fd; overflow: hidden; z-index: 0;"></div>
                    <p id="mapError" style="display: none; color: #b45309; font-size: 13px; margin-top: 10px; background: rgba(245, 158, 11, 0.1); padding: 10px 14px; border-radius: 8px;">
                        <i class="ti-info-alt"></i> Impossible de localiser cette adresse sur la carte.
                    </p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="event-action-card">
                    <h5 style="font-weight: 800; margin-bottom: 20px; color: #1e3a8a; font-size: 20px;">Réservation</h5>
                    <p style="color: #475569; margin-bottom: 16px; font-size: 15px;">Places restantes: <strong style="color: #1e40af; font-size: 18px;">{{ remaining }}</strong></p>

                    {% if remaining > 0 %}
                        <span class="event-badge badge-open"><i class="ti-check"></i> Disponible</span>
                    {% else %}
                        <span class="event-badge badge-full"><i class="ti-close"></i> Complet</span>
                    {% endif %}

                    {% if userReservation %}
                        <div style="margin-top: 20px; padding: 16px; background: white; border-radius: 16px;">
                            <p style="font-size: 13px; color: #64748b; margin-bottom: 10px;">Votre statut :</p>
                            {% if userReservation.statut == 'pending' %}
                                <span class="event-badge badge-pending"><i class="ti-time"></i> En attente de confirmation email</span>
                                <p style="font-size: 12px; color: #b45309; margin-top: 8px;">📧 Vérifiez votre boîte mail pour confirmer.</p>
                            {% elseif userReservation.statut == 'accepted' %}
                                <span class="event-badge badge-accepted"><i class="ti-check"></i>Acceptée</span>
                            {% elseif userReservation.statut == 'refused' %}
                                <span class="event-badge badge-refused"><i class="ti-close"></i>Refusée</span>
                            {% elseif userReservation.statut == 'cancelled' %}
                                <span class="event-badge badge-cancelled"><i class="ti-na"></i>Annulée</span>
                            {% endif %}
                        </div>
                    {% endif %}

                    {% if form is not null %}
                        {{ form_start(form, {'attr': {'style': 'margin-top: 24px;', 'class': 'event-form'}}) }}
                            <div class="mb-3">
                                {{ form_label(form.nom, 'Nom', {'label_attr': {'class': 'form-label', 'style': 'font-weight: 600; color: #1e3a8a; margin-bottom: 8px; display: block;'}}) }}
                                {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'style': 'border: 2px solid #dbeafe; border-radius: 12px; padding: 12px 14px; font-size: 14px;'}}) }}
                                {{ form_errors(form.nom) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.prenom, 'Prénom', {'label_attr': {'class': 'form-label', 'style': 'font-weight: 600; color: #1e3a8a; margin-bottom: 8px; display: block;'}}) }}
                                {{ form_widget(form.prenom, {'attr': {'class': 'form-control', 'style': 'border: 2px solid #dbeafe; border-radius: 12px; padding: 12px 14px; font-size: 14px;'}}) }}
                                {{ form_errors(form.prenom) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.telephone, 'Téléphone', {'label_attr': {'class': 'form-label', 'style': 'font-weight: 600; color: #1e3a8a; margin-bottom: 8px; display: block;'}}) }}
                                {{ form_widget(form.telephone, {'attr': {'class': 'form-control', 'style': 'border: 2px solid #dbeafe; border-radius: 12px; padding: 12px 14px; font-size: 14px;'}}) }}
                                {{ form_errors(form.telephone) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.commentaire, 'Commentaire (optionnel)', {'label_attr': {'class': 'form-label', 'style': 'font-weight: 600; color: #1e3a8a; margin-bottom: 8px; display: block;'}}) }}
                                {{ form_widget(form.commentaire, {'attr': {'class': 'form-control', 'style': 'border: 2px solid #dbeafe; border-radius: 12px; padding: 12px 14px; font-size: 14px; min-height: 100px;'}}) }}
                                {{ form_errors(form.commentaire) }}
                            </div>
                            <button type="submit" class="event-cta" {% if not canReserve %}disabled{% endif %}>
                                <i class="ti-check" style="margin-right: 8px;"></i>Réserver ma place
                            </button>
                        {{ form_end(form) }}
                    {% endif %}

                    {% if not app.user %}
                        <p style="margin-top: 16px; font-size: 14px; color: #1e40af; background: rgba(59, 130, 246, 0.1); padding: 12px 16px; border-radius: 12px; border-left: 4px solid #3b82f6;"><i class="ti-info-alt" style="margin-right: 8px;"></i>Connectez-vous pour réserver.</p>
                    {% endif %}
                    {% if app.user and app.user.role != 'etudiant' %}
                        <p style="margin-top: 16px; font-size: 14px; color: #ca8a04; background: rgba(245, 158, 11, 0.1); padding: 12px 16px; border-radius: 12px; border-left: 4px solid #f59e0b;"><i class="ti-alert" style="margin-right: 8px;"></i>Seuls les étudiants peuvent réserver.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Leaflet CSS & JS (OpenStreetMap) -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // ===== Countdown Timer =====
        (function() {
            const eventDate = new Date('{{ event.dateEvent|date('Y-m-d\\TH:i:s') }}');
            const cdDays = document.getElementById('cd-days');
            const cdHours = document.getElementById('cd-hours');
            const cdMinutes = document.getElementById('cd-minutes');
            const cdSeconds = document.getElementById('cd-seconds');
            const cdBoxes = document.getElementById('countdown-boxes');
            const cdPast = document.getElementById('cd-past');

            function pad(n) { return n < 10 ? '0' + n : n; }

            function updateCountdown() {
                const now = new Date();
                const diff = eventDate - now;

                if (diff <= 0) {
                    cdBoxes.style.display = 'none';
                    cdPast.style.display = 'inline-block';
                    return;
                }

                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((diff % (1000 * 60)) / 1000);

                cdDays.textContent = pad(days);
                cdHours.textContent = pad(hours);
                cdMinutes.textContent = pad(minutes);
                cdSeconds.textContent = pad(seconds);
            }

            updateCountdown();
            setInterval(updateCountdown, 1000);
        })();
    </script>
    <script>
        (function() {
            const lieu = {{ event.lieu|json_encode|raw }};
            const mapEl = document.getElementById('eventMap');
            const mapError = document.getElementById('mapError');

            // Geocode the location using Nominatim (free, no API key)
            fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(lieu) + '&limit=1', {
                headers: { 'Accept-Language': 'fr' }
            })
            .then(r => r.json())
            .then(data => {
                if (data.length === 0) {
                    // Fallback: try with "Tunisia" appended
                    return fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(lieu + ', Tunisie') + '&limit=1', {
                        headers: { 'Accept-Language': 'fr' }
                    }).then(r => r.json());
                }
                return data;
            })
            .then(data => {
                if (data.length === 0) {
                    mapError.style.display = 'block';
                    mapEl.style.display = 'none';
                    return;
                }

                const lat = parseFloat(data[0].lat);
                const lon = parseFloat(data[0].lon);

                const map = L.map('eventMap').setView([lat, lon], 15);

                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
                    maxZoom: 19
                }).addTo(map);

                // Custom marker
                const marker = L.marker([lat, lon]).addTo(map);
                marker.bindPopup(
                    '<div style="text-align: center; padding: 4px;">' +
                    '<strong style="color: #1e3a8a; font-size: 14px;">{{ event.titre|e('js') }}</strong><br>' +
                    '<span style="color: #0284c7; font-size: 12px;"><i class="ti-location-pin"></i> ' + lieu + '</span><br>' +
                    '<span style="color: #64748b; font-size: 11px;">{{ event.dateEvent|date('d/m/Y à H:i') }}</span>' +
                    '</div>'
                ).openPopup();
            })
            .catch(() => {
                mapError.style.display = 'block';
                mapEl.style.display = 'none';
            });
        })();
    </script>

    <!-- ===== AI Chatbot Widget ===== -->
    <button class="chatbot-toggle" id="chatbotToggle" title="Assistant IA MindCare">
        <i class="ti-comment-alt"></i>
        <span class="badge-dot"></span>
    </button>

    <div class="chatbot-window" id="chatbotWindow">
        <div class="chatbot-header">
            <div class="chatbot-header-avatar">🤖</div>
            <div class="chatbot-header-info">
                <h4>MindCare Assistant</h4>
                <span>IA · Événements & Statistiques</span>
            </div>
            <button class="chatbot-close" id="chatbotClose" title="Fermer">
                <i class="ti-close"></i>
            </button>
        </div>

        <div class="chatbot-messages" id="chatbotMessages">
            <div class="chat-msg bot">
                <div class="msg-label">🤖 MindCare AI</div>
                Bonjour ! 👋 Je suis l'assistant IA de MindCare. Je peux vous aider avec :
                <br>• <strong>Statistiques</strong> des événements
                <br>• <strong>Recommandations</strong> personnalisées
                <br>• <strong>Comparaisons</strong> entre événements
                <br><br>Posez-moi votre question !
            </div>
        </div>

        <div class="chatbot-suggestions" id="chatbotSuggestions">
            <button onclick="sendSuggestion('Quels événements ont encore des places ?')">📊 Places disponibles</button>
            <button onclick="sendSuggestion('Quel est le taux de remplissage global ?')">📈 Taux de remplissage</button>
            <button onclick="sendSuggestion('Recommande-moi un événement')">💡 Recommandation</button>
            <button onclick="sendSuggestion('Quels sont les événements les plus populaires ?')">🔥 Plus populaires</button>
        </div>

        <div class="chatbot-input-area">
            <input type="text" id="chatbotInput" placeholder="Posez votre question..." autocomplete="off" />
            <button id="chatbotSend" title="Envoyer"><i class="ti-arrow-right"></i></button>
        </div>
    </div>

    <script>
    (function() {
        const toggle = document.getElementById('chatbotToggle');
        const win = document.getElementById('chatbotWindow');
        const closeBtn = document.getElementById('chatbotClose');
        const messages = document.getElementById('chatbotMessages');
        const input = document.getElementById('chatbotInput');
        const sendBtn = document.getElementById('chatbotSend');
        const suggestions = document.getElementById('chatbotSuggestions');
        let isOpen = false;
        let isSending = false;

        toggle.addEventListener('click', () => {
            isOpen = !isOpen;
            win.classList.toggle('open', isOpen);
            if (isOpen) input.focus();
        });

        closeBtn.addEventListener('click', () => {
            isOpen = false;
            win.classList.remove('open');
        });

        function appendMessage(text, role) {
            const div = document.createElement('div');
            div.className = 'chat-msg ' + role;
            const label = document.createElement('div');
            label.className = 'msg-label';
            label.textContent = role === 'bot' ? '🤖 MindCare AI' : '👤 Vous';
            div.appendChild(label);
            // Format bot messages: convert markdown-like bold and newlines
            if (role === 'bot') {
                const formatted = text
                    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                    .replace(/\n/g, '<br>');
                const content = document.createElement('span');
                content.innerHTML = formatted;
                div.appendChild(content);
            } else {
                div.appendChild(document.createTextNode(text));
            }
            messages.appendChild(div);
            messages.scrollTop = messages.scrollHeight;
        }

        function showTyping() {
            const typing = document.createElement('div');
            typing.className = 'chat-typing';
            typing.id = 'chatTyping';
            typing.innerHTML = '<span></span><span></span><span></span>';
            messages.appendChild(typing);
            messages.scrollTop = messages.scrollHeight;
        }

        function hideTyping() {
            const el = document.getElementById('chatTyping');
            if (el) el.remove();
        }

        async function sendMessage(text) {
            if (isSending || !text.trim()) return;
            isSending = true;
            sendBtn.disabled = true;
            input.disabled = true;

            // Hide suggestions after first real message
            suggestions.style.display = 'none';

            appendMessage(text, 'user');
            input.value = '';
            showTyping();

            try {
                const response = await fetch('{{ path("api_chatbot") }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: text })
                });

                hideTyping();

                if (!response.ok) {
                    const err = await response.json().catch(() => ({}));
                    appendMessage(err.error || 'Erreur du serveur. Réessayez.', 'bot');
                } else {
                    const data = await response.json();
                    appendMessage(data.reply || 'Pas de réponse.', 'bot');
                }
            } catch (e) {
                hideTyping();
                appendMessage('Erreur de connexion. Vérifiez votre réseau et réessayez.', 'bot');
            }

            isSending = false;
            sendBtn.disabled = false;
            input.disabled = false;
            input.focus();
        }

        sendBtn.addEventListener('click', () => sendMessage(input.value));
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage(input.value);
            }
        });

        // Expose for suggestion buttons
        window.sendSuggestion = function(text) {
            sendMessage(text);
        };
    })();
    </script>
{% endblock %}
