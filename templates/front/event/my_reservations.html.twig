{% extends 'base.html.twig' %}

{% block title %}Mes Réservations{% endblock %}

{% block body %}
    <style>
        .reservations-container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .reservations-header {
            margin-bottom: 40px;
        }

        .reservations-header h1 {
            font-size: 32px;
            font-weight: 800;
            color: #1e3a8a;
            margin-bottom: 10px;
        }

        .reservations-header p {
            font-size: 16px;
            color: #64748b;
        }

        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: #0284c7;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s;
        }

        .back-link:hover {
            color: #0ea5e9;
        }

        .status-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            border-bottom: 2px solid #e2e8f0;
            flex-wrap: wrap;
        }

        .status-tab {
            padding: 12px 20px;
            border: none;
            background: transparent;
            color: #64748b;
            font-weight: 600;
            cursor: pointer;
            border-bottom: 3px solid transparent;
            transition: all 0.3s;
            font-size: 14px;
        }

        .status-tab:hover {
            color: #1e3a8a;
        }

        .status-tab.active {
            color: #1e3a8a;
            border-bottom-color: #0284c7;
        }

        .reservation-card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 16px;
            transition: all 0.3s;
            border: 2px solid #e2e8f0;
        }

        .reservation-card:hover {
            box-shadow: 0 4px 16px rgba(3, 105, 161, 0.15);
            transform: translateY(-2px);
            border-color: #0284c7;
        }

        .reservation-card-header {
            background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%);
            color: white;
            padding: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .reservation-card-header h3 {
            margin: 0;
            font-size: 18px;
            font-weight: 700;
        }

        .reservation-status-badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
        }

        .status-confirmed {
            background: #dcfce7;
            color: #166534;
        }

        .status-pending {
            background: #fef3c7;
            color: #b45309;
        }

        .status-waiting {
            background: #fed7aa;
            color: #b45309;
        }

        .status-refused {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-cancelled {
            background: #f3f4f6;
            color: #6b7280;
        }

        .reservation-card-content {
            padding: 20px;
        }

        .reservation-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 16px;
        }

        .info-item {
            display: flex;
            flex-direction: column;
        }

        .info-label {
            font-size: 12px;
            color: #64748b;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .info-value {
            font-size: 16px;
            color: #1e3a8a;
            font-weight: 700;
        }

        .reservation-description {
            color: #475569;
            line-height: 1.6;
            margin-bottom: 12px;
        }

        .reservation-meta {
            display: flex;
            gap: 20px;
            font-size: 14px;
            color: #64748b;
            padding-top: 12px;
            border-top: 1px solid #e2e8f0;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
        }

        .empty-state-icon {
            font-size: 64px;
            margin-bottom: 20px;
        }

        .empty-state-title {
            font-size: 24px;
            font-weight: 700;
            color: #1e3a8a;
            margin-bottom: 10px;
        }

        .empty-state-text {
            color: #64748b;
            margin-bottom: 20px;
        }

        .btn-primary {
            display: inline-block;
            background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%);
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(2, 132, 199, 0.3);
        }

        .waiting-position {
            background: #fef3c7;
            color: #b45309;
            padding: 8px 12px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 13px;
        }

        @media (max-width: 768px) {
            .reservation-info {
                grid-template-columns: 1fr;
            }

            .reservation-card-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }

            .status-tabs {
                overflow-x: auto;
            }
        }
    </style>

    <div class="reservations-container">
        <a href="{{ path('front_events_index') }}" class="back-link">← Retour aux événements</a>

        <div class="reservations-header">
            <h1>📋 Mes Réservations</h1>
            <p>Vous avez {{ totalReservations }} réservation{{ totalReservations != 1 ? 's' : '' }}</p>
        </div>

        {% if totalReservations > 0 %}
            <div class="status-tabs">
                {% if reservationsByStatus.confirmed|length > 0 %}
                    <button class="status-tab active" onclick="filterStatus('confirmed')">
                        ✅ Confirmées ({{ reservationsByStatus.confirmed|length }})
                    </button>
                {% endif %}
                {% if reservationsByStatus.pending|length > 0 %}
                    <button class="status-tab{% if reservationsByStatus.confirmed|length == 0 %} active{% endif %}" onclick="filterStatus('pending')">
                        ⏱️ En attente de confirmation ({{ reservationsByStatus.pending|length }})
                    </button>
                {% endif %}
                {% if reservationsByStatus.refused|length > 0 %}
                    <button class="status-tab" onclick="filterStatus('refused')">
                        ❌ Refusées ({{ reservationsByStatus.refused|length }})
                    </button>
                {% endif %}
                {% if reservationsByStatus.cancelled|length > 0 %}
                    <button class="status-tab" onclick="filterStatus('cancelled')">
                        🗑️  Annulées ({{ reservationsByStatus.cancelled|length }})
                    </button>
                {% endif %}
            </div>

            <!-- Confirmed Reservations -->
            <div id="confirmed" class="status-group">
                {% for reservation in reservationsByStatus.confirmed %}
                    {% set event = reservation.event %}
                    <div class="reservation-card">
                        <div class="reservation-card-header">
                            <h3>{{ event ? event.titre : 'Événement supprimé' }}</h3>
                            <span class="reservation-status-badge status-confirmed">✅ Confirmée</span>
                        </div>
                        <div class="reservation-card-content">
                            <div class="reservation-info">
                                <div class="info-item">
                                    <span class="info-label">📅 Date</span>
                                    <span class="info-value">{{ event ? event.dateEvent|date('d/m/Y H:i') : 'N/A' }}</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">📍 Lieu</span>
                                    <span class="info-value">{{ event ? event.lieu : 'N/A' }}</span>
                                </div>
                            </div>
                            {% if reservation.commentaire %}
                                <div class="reservation-description">
                                    <strong>Commentaire:</strong> {{ reservation.commentaire }}
                                </div>
                            {% endif %}
                            <div class="reservation-meta">
                                <span class="meta-item"><strong>Réservé le:</strong> {{ reservation.dateReservation|date('d/m/Y H:i') }}</span>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <!-- Pending Reservations (awaiting email confirmation) -->
            <div id="pending" class="status-group"{% if reservationsByStatus.confirmed|length > 0 %} style="display: none;"{% endif %}>
                {% for reservation in reservationsByStatus.pending %}
                    {% set event = reservation.event %}
                    <div class="reservation-card">
                        <div class="reservation-card-header">
                            <h3>{{ event ? event.titre : 'Événement supprimé' }}</h3>
                            <span class="reservation-status-badge status-pending">⏱️ En attente de confirmation</span>
                        </div>
                        <div class="reservation-card-content">
                            <div class="reservation-info">
                                <div class="info-item">
                                    <span class="info-label">📅 Date</span>
                                    <span class="info-value">{{ event ? event.dateEvent|date('d/m/Y H:i') : 'N/A' }}</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">📍 Lieu</span>
                                    <span class="info-value">{{ event ? event.lieu : 'N/A' }}</span>
                                </div>
                            </div>
                            <div style="background: #fef3c7; padding: 12px 16px; border-radius: 8px; border-left: 4px solid #f59e0b; margin-bottom: 12px;">
                                <p style="margin: 0; font-size: 14px; color: #b45309;">
                                    📧 Un email de confirmation a été envoyé. Veuillez vérifier votre boîte de réception.
                                </p>
                            </div>
                                </div>
                            </div>
                            {% if reservation.commentaire %}
                                <div class="reservation-description">
                                    <strong>Commentaire:</strong> {{ reservation.commentaire }}
                                </div>
                            {% endif %}
                            <div class="reservation-meta">
                                <span class="meta-item"><strong>Réservé le:</strong> {{ reservation.dateReservation|date('d/m/Y H:i') }}</span>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <!-- Refused Reservations -->
            <div id="refused" class="status-group" style="display: none;">
                {% for reservation in reservationsByStatus.refused %}
                    {% set event = reservation.event %}
                    <div class="reservation-card">
                        <div class="reservation-card-header">
                            <h3>{{ event ? event.titre : 'Événement supprimé' }}</h3>
                            <span class="reservation-status-badge status-refused">❌ Refusée</span>
                        </div>
                        <div class="reservation-card-content">
                            <div class="reservation-info">
                                <div class="info-item">
                                    <span class="info-label">📅 Date</span>
                                    <span class="info-value">{{ event ? event.dateEvent|date('d/m/Y H:i') : 'N/A' }}</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">📍 Lieu</span>
                                    <span class="info-value">{{ event ? event.lieu : 'N/A' }}</span>
                                </div>
                            </div>
                            <div class="reservation-meta">
                                <span class="meta-item"><strong>Refusé le:</strong> {{ reservation.dateReservation|date('d/m/Y H:i') }}</span>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <!-- Cancelled Reservations -->
            <div id="cancelled" class="status-group" style="display: none;">
                {% for reservation in reservationsByStatus.cancelled %}
                    {% set event = reservation.event %}
                    <div class="reservation-card">
                        <div class="reservation-card-header">
                            <h3>{{ event ? event.titre : 'Événement supprimé' }}</h3>
                            <span class="reservation-status-badge status-cancelled">🗑️ Annulée</span>
                        </div>
                        <div class="reservation-card-content">
                            <div class="reservation-info">
                                <div class="info-item">
                                    <span class="info-label">📅 Date</span>
                                    <span class="info-value">{{ event ? event.dateEvent|date('d/m/Y H:i') : 'N/A' }}</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">📍 Lieu</span>
                                    <span class="info-value">{{ event ? event.lieu : 'N/A' }}</span>
                                </div>
                            </div>
                            <div class="reservation-meta">
                                <span class="meta-item"><strong>Annulé le:</strong> {{ reservation.dateReservation|date('d/m/Y H:i') }}</span>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state">
                <div class="empty-state-icon">📭</div>
                <h2 class="empty-state-title">Aucune réservation</h2>
                <p class="empty-state-text">Vous n'avez pas encore réservé d'événements.</p>
                <a href="{{ path('front_events_index') }}" class="btn-primary">Découvrir les événements</a>
            </div>
        {% endif %}
    </div>

    <script>
        function filterStatus(status) {
            // Hide all groups
            document.querySelectorAll('.status-group').forEach(el => {
                el.style.display = 'none';
            });

            // Show selected group
            const element = document.getElementById(status);
            if (element) {
                element.style.display = 'block';
            }

            // Update tab active state
            document.querySelectorAll('.status-tab').forEach(tab => {
                tab.classList.remove('active');
            });
            event.target.classList.add('active');
        }
    </script>
{% endblock %}
