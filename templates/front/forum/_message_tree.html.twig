{% set likesCount = likeCounts[message.id]|default(0) %}
{% set isLiked = message.id in likedMessageIds %}

{% if message.isAnonymous %}
    {% set initials = 'A' %}
    {% set displayName = 'Anonyme' %}
{% elseif message.user %}
    {% set initials = (message.user.firstName|default('')|first ~ message.user.lastName|default('')|first)|upper %}
    {% set displayName = message.user.firstName ~ ' ' ~ message.user.lastName %}
{% else %}
    {% set initials = 'U' %}
    {% set displayName = 'Utilisateur' %}
{% endif %}

<div class="message-card" id="message-{{ message.id }}" style="border-left-width: {{ depth > 1 ? 3 : 4 }}px;">
    <div class="message-header">
        <div class="message-author">
            <div class="message-avatar">
                {{ initials }}
            </div>
            <div>
                <div style="font-weight: 600; color: #333;">
                    {{ displayName }}
                </div>
                <div class="message-date">
                    <i class="ti-time"></i>
                    {{ message.dateMessage|date('d M Y à H:i') }}
                </div>
            </div>
        </div>
    </div>

    <div class="message-content">
        {{ message.contenu }}
    </div>

    <div style="margin-top: 12px; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
        {% if app.user %}
            <button
                type="button"
                class="like-btn js-like-btn {{ isLiked ? 'liked' : '' }}"
                data-url="{{ path('front_forum_message_like', {id: message.id}) }}"
                data-token="{{ csrf_token('like_message_' ~ message.id) }}"
                data-message-id="{{ message.id }}"
            >
                <i class="ti-heart"></i>
                <span>{{ isLiked ? 'Aimé' : 'J’aime' }}</span>
            </button>

            {% if depth < maxReplyDepth %}
                <button
                    type="button"
                    class="message-reply-btn js-reply-btn"
                    data-message-id="{{ message.id }}"
                    data-author="{{ displayName }}"
                >
                    Répondre
                </button>
            {% endif %}
        {% else %}
            <span style="font-size: 13px; color: #888;">Connectez-vous pour interagir</span>
        {% endif %}

        <span style="font-size: 13px; color: #666;">
            <strong class="js-like-count" data-message-id="{{ message.id }}">{{ likesCount }}</strong> like{{ likesCount > 1 ? 's' : '' }}
        </span>
    </div>

    {% if message.attachmentPath %}
        <div style="margin-top: 15px;">
            <a href="{{ message.attachmentPath }}" download class="attachment-badge" style="font-size: 13px;">
                <i class="ti-clip"></i>
                Pièce jointe ({{ (message.attachmentSize / 1024)|round(2) }} KB)
            </a>
        </div>
    {% endif %}

    {% set children = childrenByParent[message.id]|default([]) %}
    {% if children|length > 0 and depth < maxReplyDepth %}
        <div class="message-children">
            {% for child in children %}
                {% include 'front/forum/_message_tree.html.twig' with {
                    message: child,
                    depth: depth + 1,
                    childrenByParent: childrenByParent,
                    likeCounts: likeCounts,
                    likedMessageIds: likedMessageIds,
                    maxReplyDepth: maxReplyDepth
                } only %}
            {% endfor %}
        </div>
    {% endif %}
</div>
