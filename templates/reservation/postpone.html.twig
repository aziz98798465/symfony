{% extends 'base.html.twig' %}

{% block title %}Reporter le rendez-vous{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css' rel='stylesheet' />
    <style>
        .fc-event-busy { background-color: #ff4d4d !important; border-color: #ff4d4d !important; cursor: not-allowed; }
        .selected-time-display { background-color: #e9ecef; border-left: 5px solid #0d6efd; padding: 15px; border-radius: 4px; margin-top: 20px; }
        #calendar { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin-bottom: 30px; }
    </style>
{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-primary text-white p-4">
                    <h2 class="mb-0"><i class="fa fa-calendar-alt me-3"></i>Reporter le rendez-vous</h2>
                    <p class="mb-0 mt-2 opacity-75">Proposez une nouvelle date pour votre consultation avec <strong>{{ psychologue.firstName }} {{ psychologue.lastName }}</strong></p>
                </div>
                <div class="card-body p-5">
                    
                    <div class="alert alert-info mb-4">
                        <i class="fa fa-info-circle me-2"></i>
                        <strong>Date actuelle :</strong> {{ appointment.date|date('d/m/Y H:i') }}
                        <br>
                        <em>Le nouveau créneau que vous choisirez devra être validé par le psychologue.</em>
                    </div>

                    <!-- Calendar -->
                    <div id="calendar"></div>
                    {% if form.date.vars.errors|length > 0 %}
                        <div class="alert alert-danger mt-2">
                            {% for error in form.date.vars.errors %}
                                <div class="d-flex align-items-center">
                                    <i class="fa fa-exclamation-triangle me-2"></i>
                                    {{ error.message }}
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    <!-- Selected Time Display -->
                    <div id="selectedTimeDisplay" class="selected-time-display" style="display: none;">
                        <h5 class="mb-2"><i class="fa fa-calendar-check me-2"></i>Nouveau créneau sélectionné</h5>
                        <p class="mb-0" id="selectedTimeText"></p>
                    </div>

                    <!-- Postpone Form -->
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'postponeForm'}}) }}
                        
                        <!-- Hidden datetime input -->
                        <div style="display: none;">
                            {{ form_widget(form.date) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.location, 'Type de consultation', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.location, {'attr': {'class': 'form-select form-select-lg'}}) }}
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.description, 'Notes / Détails (optionnel)', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                        </div>

                        <div class="d-grid gap-2 d-md-flex mt-5">
                            <button type="submit" class="btn btn-primary btn-lg flex-grow-1" id="submitBtn" disabled>
                                <i class="fa fa-check me-2"></i>Confirmer le report
                            </button>
                            <a href="{{ path('student_mes_rendezvous') }}" class="btn btn-outline-secondary btn-lg flex-grow-1">
                                <i class="fa fa-arrow-left me-2"></i>Annuler
                            </a>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js'></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const calendarEl = document.getElementById('calendar');
            const psychologueId = {{ psychologue.id }};
            // Use querySelector to find the datetime input reliably
            const hiddenDateInput = document.querySelector('input[type="datetime-local"]');
            const selectedTimeDisplay = document.getElementById('selectedTimeDisplay');
            const selectedTimeText = document.getElementById('selectedTimeText');
            const submitBtn = document.getElementById('submitBtn');
            
            let busySlots = [];

            // Fetch busy slots from API
            fetch(`/api/psychologue/${psychologueId}/availability`)
                .then(response => response.json())
                .then(data => {
                    busySlots = data.filter(slot => slot.id !== {{ appointment.id }}); // Don't show current appointment as busy
                    initCalendar();
                })
                .catch(error => {
                    console.error('Error fetching availability:', error);
                    initCalendar(); // Init anyway
                });

            function initCalendar() {
                const calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'timeGridWeek',
                    locale: 'fr',
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'timeGridWeek,timeGridDay'
                    },
                    slotMinTime: '09:00:00',
                    slotMaxTime: '18:00:00',
                    allDaySlot: false,
                    slotDuration: '01:00:00',
                    height: 'auto',
                    nowIndicator: true,
                    selectable: true,
                    selectConstraint: {
                        start: '00:00',
                        end: '24:00',
                    },
                    // Disable past dates
                    validRange: {
                        start: new Date().toISOString().split('T')[0]
                    },
                    events: busySlots.map(slot => ({
                        start: slot.start,
                        end: slot.end,
                        display: 'background',
                        classNames: ['fc-event-busy']
                    })),
                    select: function(info) {
                        const selectedDate = info.start;
                        const now = new Date();
                        
                        // Buffer (1 hour)
                        const minTime = new Date(now.getTime() + (60 * 60 * 1000));
                        
                        if (selectedDate < minTime) {
                            alert("Veuillez sélectionner une date au moins 1 heure à l'avenir.");
                            calendar.unselect();
                            return;
                        }

                        // Check if selected time overlaps with busy slot
                        const isBusy = busySlots.some(slot => {
                            const bStart = new Date(slot.start);
                            const bEnd = new Date(slot.end);
                            return selectedDate >= bStart && selectedDate < bEnd;
                        });

                        if (isBusy) {
                            alert("Ce créneau est déjà réservé. Veuillez en choisir un autre.");
                            calendar.unselect();
                            return;
                        }

                        // Update hidden input
                        // Format for datetime-local: YYYY-MM-DDTHH:mm
                        const offset = selectedDate.getTimezoneOffset() * 60000;
                        const localISODate = new Date(selectedDate.getTime() - offset).toISOString().slice(0, 16);
                        hiddenDateInput.value = localISODate;

                        // UI Feedback
                        selectedTimeText.innerText = selectedDate.toLocaleString('fr-FR', {
                            weekday: 'long',
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                        });
                        selectedTimeDisplay.style.display = 'block';
                        submitBtn.disabled = false;
                    }
                });
                calendar.render();

                // If date is already set (always true for postpone), enable button and show display
                if (hiddenDateInput && hiddenDateInput.value) {
                    const savedDate = new Date(hiddenDateInput.value);
                    if (savedDate > new Date()) {
                        submitBtn.disabled = false;
                        selectedTimeDisplay.style.display = 'block';
                        selectedTimeText.textContent = savedDate.toLocaleDateString('fr-FR', {
                            weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
                            hour: '2-digit', minute: '2-digit'
                        });
                    }
                }
            }
        });
    </script>
{% endblock %}
