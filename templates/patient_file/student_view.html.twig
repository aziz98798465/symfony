{% extends 'base.html.twig' %}

{% block title %}Mon Dossier Médical{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary text-white rounded-circle p-3 me-3">
                        <i class="fa fa-notes-medical fa-2x"></i>
                    </div>
                    <h1 class="h2 mb-0">Mon Dossier Médical</h1>
                </div>

                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                        <h5 class="card-title mb-0">Informations de santé</h5>
                        <p class="text-muted small mb-0">Ces informations aident votre psychologue à mieux vous accompagner. Elles restent confidentielles.</p>
                    </div>
                    <div class="card-body p-4">
                        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                            
                            <div class="row mb-4">
                                <div class="col-12">
                                    <div class="mb-3">
                                        {{ form_label(form.traitementsEnCours, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                        {{ form_widget(form.traitementsEnCours) }}
                                        {{ form_errors(form.traitementsEnCours) }}
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="mb-3">
                                        {{ form_label(form.allergies, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                        {{ form_widget(form.allergies) }}
                                        {{ form_errors(form.allergies) }}
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-12 mb-3">
                                    <h6 class="text-uppercase text-primary fw-bold small border-bottom pb-2">Contact d'Urgence</h6>
                                </div>
                                <div class="col-md-6 mb-3">
                                    {{ form_label(form.contactUrgenceNom, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                    {{ form_widget(form.contactUrgenceNom) }}
                                    {{ form_errors(form.contactUrgenceNom) }}
                                </div>
                                <div class="col-md-6 mb-3">
                                    {{ form_label(form.contactUrgenceTel, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                    {{ form_widget(form.contactUrgenceTel) }}
                                    {{ form_errors(form.contactUrgenceTel) }}
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                                <div class="text-muted small">
                                    {% if patientFile.updatedAt %}
                                        Dernière mise à jour : {{ patientFile.updatedAt|date('d/m/Y H:i') }}
                                    {% endif %}
                                </div>
                                <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                    <i class="fa fa-save me-2"></i>Enregistrer les modifications
                                </button>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>

                <div class="alert alert-light border shadow-sm">
                    <div class="d-flex">
                        <div class="me-3 text-info">
                            <i class="fa fa-info-circle fa-lg"></i>
                        </div>
                        <div>
                            <h6 class="mb-1">Note sur la confidentialité</h6>
                            <p class="mb-0 small text-muted">Seuls vous, votre psychologue et l'administrateur de la plateforme ont accès à ces informations. Vos données cliniques détaillées sont gérées exclusivement par votre psychologue.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
