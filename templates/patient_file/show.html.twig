{% extends 'admin/base_admin.html.twig' %}

{% block title %}Dossier de {{ student.firstName }} {{ student.lastName }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .clinical-section { border-left: 4px solid #0d6efd; padding-left: 1.5rem; margin-bottom: 2rem; background: #f8f9fa; padding: 1.5rem; border-radius: 0 8px 8px 0; }
        .risk-badge { font-size: 0.9rem; padding: 0.5rem 1rem; border-radius: 50px; }
        .risk-low { background-color: #d1e7dd; color: #0f5132; }
        .risk-medium { background-color: #fff3cd; color: #664d03; }
        .risk-high { background-color: #f8d7da; color: #842029; }
        .readonly-value { background-color: #e9ecef; border: 1px solid #ced4da; padding: 0.75rem; border-radius: 0.375rem; min-height: 38px; display: block; width: 100%; color: #212529; }
    </style>
{% endblock %}

{% block body %}
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="{{ path('admin_patient_file_index') }}">Dossiers Étudiants</a></li>
                        <li class="breadcrumb-item active">Dossier Médical</li>
                    </ol>
                </nav>
                <h1 class="h3 mb-0">Dossier de {{ student.firstName }} {{ student.lastName }}</h1>
            </div>
            
            <div class="d-flex gap-2">
                <a href="{{ path('admin_patient_file_index') }}" class="btn btn-outline-secondary">
                    <i class="fa fa-arrow-left me-1"></i>Retour à la liste
                </a>
                {% if not isAdmin and not isNew %}
                    <form action="{{ path('admin_patient_file_delete', {id: student.id}) }}" method="POST" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce dossier clinique ? Cette action est irréversible.');">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="fa fa-trash me-1"></i>Supprimer
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>

        {% if isNew and not isAdmin %}
            <div class="alert alert-info border-0 shadow-sm mb-4">
                <i class="fa fa-info-circle me-2"></i>Ce dossier n'existe pas encore. Enregistrer ce formulaire le créera officiellement.
            </div>
        {% endif %}

        {% if isAdmin %}
            <div class="alert alert-info border-0 shadow-sm mb-4">
                <i class="fa fa-info-circle me-2"></i><strong>Permissions Administrateur :</strong> Vous pouvez modifier le **Contexte de l'Étudiant** (contacts, allergies, traitements). Les notes cliniques et le niveau de risque restent réservés aux psychologues.
            </div>
        {% endif %}

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="row">
                <!-- Column 1: Personal & Medical Context -->
                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 mb-4 h-100">
                        <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                            <h5 class="card-title fw-bold"><i class="fa fa-user-circle me-2 text-primary"></i>Contexte de l'Étudiant</h5>
                        </div>
                        <div class="card-body px-4">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Email</label>
                                <div class="readonly-value">{{ student.email }}</div>
                            </div>
                            
                            <hr class="my-4">
                            
                            <div class="mb-3">
                                {{ form_label(form.contactUrgenceNom, 'Contact d\'Urgence', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.contactUrgenceNom) }}
                                {{ form_errors(form.contactUrgenceNom) }}
                            </div>
                            
                            <div class="mb-4">
                                {{ form_label(form.contactUrgenceTel, 'Téléphone Urgence', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.contactUrgenceTel) }}
                                {{ form_errors(form.contactUrgenceTel) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(form.traitementsEnCours, 'Traitements en Cours', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.traitementsEnCours) }}
                                {{ form_errors(form.traitementsEnCours) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(form.allergies, 'Allergies', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.allergies) }}
                                {{ form_errors(form.allergies) }}
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Column 2: Clinical Dossier -->
                <div class="col-lg-8">
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                            <h5 class="card-title fw-bold"><i class="fa fa-file-medical-alt me-2 text-primary"></i>Analyse Clinique</h5>
                            <div class="d-flex align-items-center">
                                <span class="me-2 small fw-bold">Risque estimé :</span>
                                {% if isAdmin %}
                                    <span class="risk-badge risk-{{ patientFile.niveauRisque|lower }}">{{ patientFile.niveauRisque|default('Non défini') }}</span>
                                    <div style="display:none;">{{ form_widget(form.niveauRisque) }}</div>
                                {% else %}
                                    {{ form_widget(form.niveauRisque) }}
                                {% endif %}
                            </div>
                        </div>
                        <div class="card-body px-4">
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <div class="clinical-section">
                                        {{ form_label(form.motifConsultation, 'Motif Initial', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                        {{ form_widget(form.motifConsultation) }}
                                        {{ form_errors(form.motifConsultation) }}
                                    </div>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <div class="clinical-section">
                                        {{ form_label(form.objectifsTherapeutiques, 'Objectifs Thérapeutiques', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                        {{ form_widget(form.objectifsTherapeutiques) }}
                                        {{ form_errors(form.objectifsTherapeutiques) }}
                                    </div>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <div class="clinical-section border-primary">
                                        {{ form_label(form.antecedentsPersonnels, 'Antécédents Personnels', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                        {{ form_widget(form.antecedentsPersonnels) }}
                                        {{ form_errors(form.antecedentsPersonnels) }}
                                    </div>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <div class="clinical-section border-primary">
                                        {{ form_label(form.antecedentsFamiliaux, 'Antécédents Familiaux', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                        {{ form_widget(form.antecedentsFamiliaux) }}
                                        {{ form_errors(form.antecedentsFamiliaux) }}
                                    </div>
                                </div>
                                <div class="col-12 mb-4">
                                    <div class="clinical-section border-dark bg-light shadow-sm">
                                        {{ form_label(form.notesGenerales, 'Synthèse & Notes Professionnelles (Confidentiel)', {'label_attr': {'class': 'form-label fw-bold text-dark'}}) }}
                                        {{ form_widget(form.notesGenerales) }}
                                        {{ form_errors(form.notesGenerales) }}
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 pb-4 px-4">
                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                                    <i class="fa fa-save me-2"></i>Enregistrer les modifications
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    <!-- AI Clinical Insights (On-Demand) -->
                    {% if canGenerateAI %}
                        <div class="card shadow-sm border-0 mb-4 border-start border-4 border-info">
                            <div class="card-header bg-gradient bg-info bg-opacity-10 border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="card-title fw-bold text-info mb-0">
                                        <i class="fa fa-brain me-2"></i>Analyse IA - Observations Cliniques
                                    </h5>
                                    <small class="text-muted">Intelligence artificielle</small>
                                </div>
                                <button id="generateAiBtn" class="btn btn-info btn-sm" onclick="generateAI()">
                                    <i class="fa fa-magic me-1"></i>Générer les Insights
                                </button>
                            </div>
                            <div class="card-body px-4" id="aiInsightsContainer">
                                <div class="alert alert-light border-info text-center py-4" id="aiPlaceholder">
                                    <i class="fa fa-robot fa-2x text-info mb-2"></i>
                                    <p class="mb-0">Cliquez sur "Générer les Insights" pour obtenir une analyse IA</p>
                                </div>
                                <div id="aiLoading" class="text-center py-4" style="display:none;">
                                    <div class="spinner-border text-info" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <p class="mt-2 text-muted">Génération en cours... (peut prendre 10-30s)</p>
                                </div>
                                <div id="aiContent" style="display:none;">
                                    <div class="alert alert-light border-info">
                                        <p class="mb-0" style="white-space: pre-wrap;" id="aiText"></p>
                                    </div>
                                    <div class="text-muted small">
                                        <i class="fa fa-info-circle me-1"></i>
                                        Ces observations sont générées par IA et doivent être validées par un professionnel.
                                    </div>
                                </div>
                                <div id="aiError" class="alert alert-danger" style="display:none;">
                                    <i class="fa fa-exclamation-triangle me-2"></i>
                                    <span id="aiErrorText"></span>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                    
                    <div class="text-muted small text-end">
                        {% if patientFile.createdAt %}
                            Initialisé le : {{ patientFile.createdAt|date('d/m/Y H:i') }} | 
                        {% endif %}
                        {% if patientFile.updatedAt %}
                            Dernière modification : {{ patientFile.updatedAt|date('d/m/Y H:i') }}
                        {% endif %}
                    </div>
                </div>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function generateAI() {
            const btn = document.getElementById('generateAiBtn');
            const placeholder = document.getElementById('aiPlaceholder');
            const loading = document.getElementById('aiLoading');
            const content = document.getElementById('aiContent');
            const error = document.getElementById('aiError');
            
            // Hide everything and show loading
            btn.disabled = true;
            placeholder.style.display = 'none';
            content.style.display = 'none';
            error.style.display = 'none';
            loading.style.display = 'block';
            
            // Make AJAX request
            fetch('{{ path('admin_patient_file_ai_insights', {id: student.id}) }}', {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                loading.style.display = 'none';
                
                if (data.insights) {
                    document.getElementById('aiText').textContent = data.insights;
                    content.style.display = 'block';
                } else if (data.error) {
                    document.getElementById('aiErrorText').textContent = data.error;
                    error.style.display = 'block';
                    btn.disabled = false;
                }
            })
            .catch(err => {
                loading.style.display = 'none';
                document.getElementById('aiErrorText').textContent = 'Erreur de connexion: ' + err.message;
                error.style.display = 'block';
                btn.disabled = false;
            });
        }
    </script>
{% endblock %}