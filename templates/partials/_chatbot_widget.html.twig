{# ============================================================
   Chatbot widget flottant — Ressources & Commentaires
   Inclure avec : {% include 'partials/_chatbot_widget.html.twig' %}
   ============================================================ #}

<!-- ========== CHATBOT STYLES ========== -->
<style>
/* ── Bouton flottant ── */
#chatbot-toggle {
    position: fixed;
    bottom: 28px;
    right: 28px;
    width: 62px;
    height: 62px;
    border-radius: 50%;
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    color: #fff;
    border: none;
    box-shadow: 0 6px 22px rgba(79,70,229,.45);
    cursor: pointer;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    transition: transform .2s, box-shadow .2s;
}
#chatbot-toggle:hover { transform: scale(1.10); box-shadow: 0 8px 28px rgba(79,70,229,.55); }

/* Badge nouveau message */
#chatbot-badge {
    position: absolute;
    top: 2px; right: 2px;
    width: 14px; height: 14px;
    background: #ef4444;
    border-radius: 50%;
    border: 2px solid #fff;
    display: none;
}

/* ── Fenêtre du chat ── */
#chatbot-window {
    position: fixed;
    bottom: 105px;
    right: 28px;
    width: 370px;
    max-height: 540px;
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 12px 50px rgba(0,0,0,.18);
    display: none;
    flex-direction: column;
    overflow: hidden;
    z-index: 9998;
    font-family: 'Segoe UI', sans-serif;
    animation: cbSlideIn .22s ease;
}
@keyframes cbSlideIn {
    from { opacity: 0; transform: translateY(18px) scale(.96); }
    to   { opacity: 1; transform: translateY(0)      scale(1);  }
}

/* ── Entête ── */
#chatbot-header {
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    color: #fff;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 10px;
}
#chatbot-header .cb-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,.25);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
}
#chatbot-header .cb-info { flex: 1; }
#chatbot-header .cb-name { font-weight: 700; font-size: 15px; }
#chatbot-header .cb-status { font-size: 11px; opacity: .85; }
#chatbot-close {
    background: none; border: none; color: #fff;
    font-size: 20px; cursor: pointer; padding: 0 2px;
    opacity: .8; transition: opacity .15s;
}
#chatbot-close:hover { opacity: 1; }

/* ── Zone messages ── */
#chatbot-messages {
    flex: 1;
    overflow-y: auto;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: #f8f7ff;
}
#chatbot-messages::-webkit-scrollbar { width: 5px; }
#chatbot-messages::-webkit-scrollbar-thumb { background: #c7c5f0; border-radius: 4px; }

.cb-msg {
    max-width: 82%;
    padding: 9px 13px;
    border-radius: 14px;
    font-size: 13.5px;
    line-height: 1.5;
    word-break: break-word;
}
.cb-msg.bot {
    background: #fff;
    border: 1px solid #e0dff8;
    border-bottom-left-radius: 4px;
    align-self: flex-start;
    color: #222;
}
.cb-msg.user {
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    color: #fff;
    border-bottom-right-radius: 4px;
    align-self: flex-end;
}
.cb-msg.error {
    background: #fee2e2;
    border: 1px solid #fca5a5;
    border-bottom-left-radius: 4px;
    align-self: flex-start;
    color: #b91c1c;
    font-size: 12.5px;
}
.cb-resource-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 6px;
    padding: 5px 12px;
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    color: #fff !important;
    border-radius: 20px;
    font-size: 12.5px;
    font-weight: 600;
    text-decoration: none !important;
    transition: opacity .2s;
}
.cb-resource-btn:hover { opacity: .85; }

/* Typing indicator */
.cb-typing { display: flex; gap: 5px; align-items: center; padding: 10px 13px; }
.cb-typing span {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #a49df0;
    animation: cbBounce 1.2s infinite;
}
.cb-typing span:nth-child(2) { animation-delay: .2s; }
.cb-typing span:nth-child(3) { animation-delay: .4s; }
@keyframes cbBounce {
    0%,80%,100% { transform: translateY(0); }
    40%          { transform: translateY(-6px); }
}

/* Suggestions rapides */
#chatbot-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 6px 16px 2px;
    background: #f8f7ff;
}
.cb-chip {
    background: #ede9fe;
    color: #4f46e5;
    border: 1px solid #c4b5fd;
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 12px;
    cursor: pointer;
    transition: background .15s;
    white-space: nowrap;
}
.cb-chip:hover { background: #ddd6fe; }

/* ── Zone de saisie ── */
#chatbot-form {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px;
    border-top: 1px solid #e5e3f8;
    background: #fff;
}
#chatbot-input {
    flex: 1;
    border: 1px solid #d1d0f0;
    border-radius: 22px;
    padding: 9px 15px;
    font-size: 13.5px;
    outline: none;
    transition: border-color .2s;
    resize: none;
    background: #fafafe;
}
#chatbot-input:focus { border-color: #7c3aed; background: #fff; }
#chatbot-send {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
    transition: opacity .2s;
}
#chatbot-send:disabled { opacity: .5; cursor: default; }

@media (max-width: 440px) {
    #chatbot-window { width: calc(100vw - 24px); right: 12px; bottom: 90px; }
    #chatbot-toggle { bottom: 16px; right: 16px; }
}
</style>

<!-- ========== CHATBOT HTML ========== -->

<!-- Bouton flottant -->
<button id="chatbot-toggle" aria-label="Ouvrir l'assistant MindCare" title="Assistant MindCare">
    💬
    <span id="chatbot-badge"></span>
</button>

<!-- Fenêtre de chat -->
<div id="chatbot-window" role="dialog" aria-label="Assistant MindCare">
    <!-- Entête -->
    <div id="chatbot-header">
        <div class="cb-avatar">🤖</div>
        <div class="cb-info">
            <div class="cb-name">Assistant MindCare</div>
            <div class="cb-status">Ressources &amp; Commentaires</div>
        </div>
        <button id="chatbot-close" aria-label="Fermer">✕</button>
    </div>

    <!-- Messages -->
    <div id="chatbot-messages">
        <div class="cb-msg bot">
            Bonjour ! 👋 Je suis votre assistant MindCare.<br>
            Je peux vous aider à <strong>trouver une ressource</strong> (article ou vidéo)
            selon votre humeur, ou vous guider pour <strong>laisser un commentaire</strong>.
        </div>
    </div>

    <!-- Suggestions rapides -->
    <div id="chatbot-suggestions">
        <button class="cb-chip" data-msg="Je me sens anxieux, quelle ressource me conseilles-tu ?">Anxiété</button>
        <button class="cb-chip" data-msg="Je veux une vidéo sur la gestion du stress">Stress</button>
        <button class="cb-chip" data-msg="Comment laisser un commentaire ?">Commentaires</button>
        <button class="cb-chip" data-msg="Montre-moi les meilleures ressources disponibles">Top ressources</button>
    </div>

    <!-- Formulaire -->
    <form id="chatbot-form" autocomplete="off">
        <input
            id="chatbot-input"
            type="text"
            placeholder="Posez votre question..."
            aria-label="Message à l'assistant"
            maxlength="500"
        >
        <button id="chatbot-send" type="submit" aria-label="Envoyer">
            ➤
        </button>
    </form>
</div>

<!-- ========== CHATBOT JS ========== -->
<script>
(function () {
    const toggle    = document.getElementById('chatbot-toggle');
    const window_   = document.getElementById('chatbot-window');
    const closeBtn  = document.getElementById('chatbot-close');
    const form      = document.getElementById('chatbot-form');
    const input     = document.getElementById('chatbot-input');
    const sendBtn   = document.getElementById('chatbot-send');
    const messages  = document.getElementById('chatbot-messages');
    const badge     = document.getElementById('chatbot-badge');
    const chips     = document.querySelectorAll('.cb-chip');

    const ENDPOINT = '{{ path('chatbot_resource') }}';
    let history    = [];   // [{role, content}]
    let isOpen     = false;
    let isLoading  = false;

    // ── Open / Close ──────────────────────────────────────────
    toggle.addEventListener('click', () => {
        isOpen = !isOpen;
        window_.style.display = isOpen ? 'flex' : 'none';
        toggle.textContent = isOpen ? '✕' : '💬';
        if (isOpen) {
            badge.style.display = 'none';
            input.focus();
            scrollToBottom();
        }
    });

    closeBtn.addEventListener('click', () => {
        isOpen = false;
        window_.style.display = 'none';
        toggle.textContent = '💬';
    });

    // ── Chips ─────────────────────────────────────────────────
    chips.forEach(chip => {
        chip.addEventListener('click', () => {
            const msg = chip.dataset.msg || chip.textContent;
            sendMessage(msg);
        });
    });

    // ── Submit ────────────────────────────────────────────────
    form.addEventListener('submit', e => {
        e.preventDefault();
        const text = input.value.trim();
        if (!text || isLoading) return;
        input.value = '';
        sendMessage(text);
    });

    // Entrée sans shift = envoyer
    input.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            form.dispatchEvent(new Event('submit'));
        }
    });

    // ── Core send ─────────────────────────────────────────────
    function sendMessage(text) {
        if (!text || isLoading) return;

        appendMessage('user', text);
        history.push({ role: 'user', content: text });

        const typingEl = appendTyping();
        setLoading(true);

        fetch(ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ message: text, history: history.slice(0, -1) }),
        })
        .then(res => res.json().then(data => ({ ok: res.ok, data })))
        .then(({ ok, data }) => {
            typingEl.remove();
            if (ok && data.reply) {
                appendMessage('bot', data.reply);
                history.push({ role: 'assistant', content: data.reply });
                if (!isOpen) showBadge();
            } else {
                appendMessage('error', data.error || 'Erreur inconnue. Réessayez.');
            }
        })
        .catch(() => {
            typingEl.remove();
            appendMessage('error', 'Impossible de contacter le serveur. Vérifiez votre connexion.');
        })
        .finally(() => setLoading(false));
    }

    // ── Helpers ───────────────────────────────────────────────
    function appendMessage(type, text) {
        const div = document.createElement('div');
        div.className = 'cb-msg ' + type;
        // Safe: convert [ID:N], (ID:N) or ID:N to clickable button
        div.innerHTML = escapeHtml(text)
            .replace(/(?:\[\s*ID\s*:\s*(\d+)\s*\]|\(\s*ID\s*:\s*(\d+)\s*\)|\bID\s*:\s*(\d+)\b)/gi, (_, id1, id2, id3) => {
                const resourceId = id1 || id2 || id3;
                return '<a href="/resources/' + resourceId + '" class="cb-resource-btn">📖 Ouvrir la ressource</a>';
            });
        messages.appendChild(div);
        scrollToBottom();
        return div;
    }

    function appendTyping() {
        const div = document.createElement('div');
        div.className = 'cb-msg bot cb-typing';
        div.innerHTML = '<span></span><span></span><span></span>';
        messages.appendChild(div);
        scrollToBottom();
        return div;
    }

    function escapeHtml(str) {
        return str
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/\n/g, '<br>');
    }

    function scrollToBottom() {
        messages.scrollTop = messages.scrollHeight;
    }

    function setLoading(state) {
        isLoading = state;
        sendBtn.disabled = state;
        input.disabled   = state;
    }

    function showBadge() {
        badge.style.display = 'block';
        toggle.textContent  = '💬';
    }
})();
</script>
